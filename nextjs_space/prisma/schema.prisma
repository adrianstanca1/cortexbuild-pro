// PHASE 3: INNOVATION LAYER
// ============================================

// Automation Rules Engine
model AutomationRule {
  id String @id @default(cuid())

  name        String
  description String? @db.Text

  // Scope
  organizationId String
  organization   Organization @relation("OrgAutomationRules", fields: [organizationId], references: [id])
  projectId      String? // If null, applies to all projects
  project        Project?     @relation("ProjectAutomationRules", fields: [projectId], references: [id], onDelete: Cascade)

  // Trigger conditions (JSON)
  triggerType      String // THRESHOLD, SCHEDULE, EVENT
  triggerCondition Json // { "field": "costVariance", "operator": ">", "value": 10 }

  // Actions (JSON array)
  actions Json // [{ "type": "NOTIFY", "recipients": ["role:PM"], "message": "..." }]

  // Notification settings
  notifyRoles     String[] @default([])
  notifyUsers     String[] @default([])
  escalationDelay Int? // Minutes before escalation

  // Status
  isActive        Boolean   @default(true)
  lastTriggeredAt DateTime?
  triggerCount    Int       @default(0)

  // Audit
  createdById String
  createdBy   User   @relation("AutomationRuleCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Execution log
  executionLogs RuleExecutionLog[]

  @@index([organizationId])
  @@index([projectId])
  @@index([isActive])
  @@index([triggerType])
}

// Rule Execution Log
model RuleExecutionLog {
  id String @id @default(cuid())

  ruleId String
  rule   AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  executedAt      DateTime @default(now())
  triggerData     Json? // What triggered the rule
  actionsExecuted Json? // What actions were taken
  success         Boolean  @default(true)
  errorMessage    String?  @db.Text

  @@index([ruleId])
  @@index([executedAt])
}

// Predictive Signals (deterministic, non-ML)
model PredictiveSignal {
  id String @id @default(cuid())

  // Scope
  organizationId String
  organization   Organization @relation("OrgPredictiveSignals", fields: [organizationId], references: [id])
  projectId      String?
  project        Project?     @relation("ProjectPredictiveSignals", fields: [projectId], references: [id], onDelete: Cascade)

  // Signal identification
  signalType  String // PRODUCTIVITY_DECLINE, COST_OVERRUN_RISK, SCHEDULE_SLIP, REWORK_PATTERN, CHANGE_FREQUENCY_SPIKE
  signalName  String
  description String? @db.Text

  // Detection
  detectedAt DateTime @default(now())

  // Severity
  severity   String @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  confidence Float  @default(0.7) // 0-1

  // Supporting data
  dataPoints     Json? // Array of data points supporting the signal
  trendDirection String? // UP, DOWN, STABLE
  trendDuration  Int? // Days of trend

  // Impact assessment
  potentialImpact         String? @db.Text
  potentialCostImpact     Float?
  potentialScheduleImpact Int?

  // Recommended actions
  recommendations String[] @default([])

  // Status
  status           String    @default("ACTIVE") // ACTIVE, ACKNOWLEDGED, RESOLVED, DISMISSED
  acknowledgedById String?
  acknowledgedBy   User?     @relation("SignalAcknowledger", fields: [acknowledgedById], references: [id])
  acknowledgedAt   DateTime?
  resolvedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([projectId])
  @@index([signalType])
  @@index([severity])
  @@index([status])
}

// Vendor Portal Access (controlled external access)
model VendorPortalAccess {
  id String @id @default(cuid())

  // Vendor/Subcontractor linkage
  subcontractorId String
  subcontractor   Subcontractor @relation("SubcontractorPortalAccess", fields: [subcontractorId], references: [id], onDelete: Cascade)

  // Access credentials (email-based)
  email        String
  passwordHash String

  // Token for session management
  accessToken    String?
  tokenExpiresAt DateTime?

  // Permissions (JSON array of allowed actions)
  permissions Json // ["view_schedule", "submit_progress", "upload_documents", "view_payments"]

  // Project access (if empty, all projects with subcontractor)
  projectIds String[] @default([])

  // Status
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  loginCount  Int       @default(0)

  // Audit
  createdById String
  createdBy   User   @relation("VendorAccessCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Submissions from this vendor
  submissions VendorSubmission[]

  @@unique([subcontractorId, email])
  @@index([subcontractorId])
  @@index([email])
  @@index([isActive])
}

// Vendor Submission (progress, invoices, compliance docs)
model VendorSubmission {
  id String @id @default(cuid())

  // Vendor access linkage
  vendorAccessId String
  vendorAccess   VendorPortalAccess @relation(fields: [vendorAccessId], references: [id], onDelete: Cascade)

  // Submission type
  submissionType String // PROGRESS_UPDATE, INVOICE, COMPLIANCE_DOC, CERTIFICATION, SCHEDULE_UPDATE

  // Project linkage
  projectId String
  project   Project @relation("ProjectVendorSubmissions", fields: [projectId], references: [id], onDelete: Cascade)

  // Content
  title       String
  description String? @db.Text

  // For progress updates
  percentComplete Float?
  workDescription String? @db.Text

  // For invoices
  invoiceNumber String?
  invoiceAmount Float?
  invoiceDate   DateTime?

  // Attachments
  attachments VendorSubmissionAttachment[]

  // Approval workflow
  status         String    @default("SUBMITTED") // SUBMITTED, UNDER_REVIEW, APPROVED, REJECTED, NEEDS_REVISION
  reviewedById   String?
  reviewedBy     User?     @relation("VendorSubmissionReviewer", fields: [reviewedById], references: [id])
  reviewedAt     DateTime?
  reviewComments String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vendorAccessId])
  @@index([projectId])
  @@index([submissionType])
  @@index([status])
}

model VendorSubmissionAttachment {
  id           String           @id @default(cuid())
  submissionId String
  submission   VendorSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  name             String
  cloudStoragePath String
  fileSize         Int?
  mimeType         String?

  createdAt DateTime @default(now())

  @@index([submissionId])
}

