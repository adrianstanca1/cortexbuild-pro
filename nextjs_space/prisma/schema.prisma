  createdAt        DateTime @default(now())
}

// Drawing Status
enum DrawingStatus {
  DRAFT
  FOR_REVIEW
  APPROVED
  SUPERSEDED
  VOID
}

// Drawing Discipline
enum DrawingDiscipline {
  ARCHITECTURAL
  STRUCTURAL
  MECHANICAL
  ELECTRICAL
  PLUMBING
  CIVIL
  LANDSCAPE
  FIRE_PROTECTION
  INTERIOR
  SHOP_DRAWING
  AS_BUILT
  OTHER
}

// Drawing Management
model Drawing {
  id              String              @id @default(cuid())
  number          String // Drawing number e.g., "A-101"
  title           String
  description     String?             @db.Text
  discipline      DrawingDiscipline   @default(ARCHITECTURAL)
  status          DrawingStatus       @default(DRAFT)
  currentRevision String              @default("0") // e.g., "A", "B", "1", "2"
  scale           String? // e.g., "1:100", "1/4\" = 1'-0\""
  sheetSize       String? // e.g., "A1", "A0", "24x36"
  projectId       String
  project         Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  revisions       DrawingRevision[]
  annotations     DrawingAnnotation[]

  @@unique([projectId, number])
  @@index([projectId])
  @@index([discipline])
  @@index([status])
}

model DrawingRevision {
  id               String   @id @default(cuid())
  revision         String // e.g., "A", "B", "1"
  description      String?  @db.Text // What changed in this revision
  cloudStoragePath String
  fileSize         Int?
  mimeType         String?
  issuedDate       DateTime @default(now())
  issuedBy         String? // Name of person/company issuing
  drawingId        String
  drawing          Drawing  @relation(fields: [drawingId], references: [id], onDelete: Cascade)
  uploadedById     String?
  uploadedBy       User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())

  @@unique([drawingId, revision])
  @@index([drawingId])
}

// Drawing Annotations for markup and review
model DrawingAnnotation {
  id          String   @id @default(cuid())
  drawingId   String
  drawing     Drawing  @relation(fields: [drawingId], references: [id], onDelete: Cascade)
  type        String // pen, brush, highlighter, marker, spray, text, rectangle, filledRectangle, roundedRectangle, circle, filledCircle, ellipse, triangle, polygon, star, arrow, doubleArrow, line, cloud, cloudRevision, callout, speechBubble, measurement, areaMeasurement, angleMeasurement, dimension, leader, bezier, spline, crosshatch, stamp, etc.
  data        Json // Stores the annotation data (points, coordinates, etc.)
  color       String   @default("#FF0000")
  fillColor   String?  @default("#FF0000")
  strokeWidth Int      @default(3)
  opacity     Float    @default(1)
  text        String?  @db.Text // For text annotations
  fontFamily  String?  @default("Arial")
  fontSize    Int?     @default(16)
  fontStyle   String?  @default("normal")
  visible     Boolean  @default(true)
  locked      Boolean  @default(false)
  layer       Int      @default(0)
  transform   Json? // For rotation, scale, translation
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([drawingId])
  @@index([createdById])
}

// Site Diary Entry Types
enum DiaryEntryType {
  GENERAL
  WEATHER
  VISITOR
  DELIVERY
  INCIDENT
  MILESTONE
  DELAY
  PROGRESS
  INSTRUCTION
  VARIATION
}

// Enhanced Site Diary
model SiteDiary {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Weather Info
  weatherMorning   String?
  weatherAfternoon String?
  tempMorning      Float?
  tempAfternoon    Float?

  // Work Summary
  workAreas    String? @db.Text // Areas worked on
  workProgress String? @db.Text // Progress description

  // Resources
  labourCount     Int     @default(0)
  subcontractors  String? @db.Text // Subs on site
  equipmentOnSite String? @db.Text

  // Issues & Notes
  delays             String? @db.Text
  healthSafety       String? @db.Text
  qualityIssues      String? @db.Text
  clientInstructions String? @db.Text
