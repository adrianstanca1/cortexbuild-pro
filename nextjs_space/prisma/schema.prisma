  AREA
  SCATTER
  HEATMAP
  GAUGE
  TABLE
}

enum AnalyticsPeriod {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
  CUSTOM
}

model AnalyticsWidget {
  id          String             @id @default(cuid())
  name        String
  description String?
  chartType   AnalyticsChartType

  // Data source configuration
  dataSource String // e.g., "projects", "tasks", "costs"
  query      Json // Query configuration for data

  // Display settings
  position Json? // { x, y, width, height }
  settings Json? // Chart-specific settings

  // Filtering
  filters Json? // User-defined filters
  period  AnalyticsPeriod @default(MONTHLY)

  // Organization context
  organizationId String?
  organization   Organization? @relation("OrgAnalyticsWidgets", fields: [organizationId], references: [id], onDelete: Cascade)

  // Dashboard relationship
  dashboardId String?
  dashboard   AnalyticsDashboard? @relation("DashboardWidgets", fields: [dashboardId], references: [id], onDelete: Cascade)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([dashboardId])
}

model AnalyticsDashboard {
  id          String  @id @default(cuid())
  name        String
  description String?

  // Layout configuration
  layout Json? // Grid layout configuration

  // Widgets
  widgets AnalyticsWidget[] @relation("DashboardWidgets")

  // Sharing and permissions
  isPublic  Boolean @default(false)
  isDefault Boolean @default(false)

  // Organization context
  organizationId String?
  organization   Organization? @relation("OrgAnalyticsDashboards", fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([isDefault])
}

// ============================================================
// Advanced Features - Backup and Restore
// ============================================================

enum BackupType {
  FULL
  INCREMENTAL
  DIFFERENTIAL
}

enum BackupStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  EXPIRED
}

model BackupConfiguration {
  id          String  @id @default(cuid())
  name        String
  description String?

  // Backup settings
  backupType BackupType @default(FULL)
  schedule   String? // Cron expression
  retention  Int        @default(30) // Days

  // What to backup
  includeDocuments Boolean @default(true)
  includeDatabase  Boolean @default(true)
  includeMedia     Boolean @default(true)

  // Compression and encryption
  isCompressed Boolean @default(true)
  isEncrypted  Boolean @default(true)

  // Organization context
  organizationId String?
  organization   Organization? @relation("OrgBackupConfigs", fields: [organizationId], references: [id], onDelete: Cascade)

  // Backup history
  backups BackupRecord[] @relation("ConfigBackups")

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([isActive])
}

model BackupRecord {
  id String @id @default(cuid())

  // Backup details
  backupType BackupType
  status     BackupStatus @default(PENDING)

  // Storage information
  fileName        String
  fileSize        BigInt? // Bytes
  filePath        String?
  storageLocation String? // S3 bucket, local path, etc.

  // Metadata
  recordCount  Json? // Count of records backed up by model
  errorMessage String?

  // Timing
  startedAt   DateTime?
  completedAt DateTime?
  expiresAt   DateTime?

  // Configuration
  configId      String?
  configuration BackupConfiguration? @relation("ConfigBackups", fields: [configId], references: [id], onDelete: SetNull)

  // Organization context
  organizationId String?
  organization   Organization? @relation("OrgBackupRecords", fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([status])
  @@index([expiresAt])
}

// ============================================================
// Advanced Features - Scheduled Tasks
// ============================================================

enum ScheduledTaskType {
  BACKUP
  REPORT_GENERATION
  DATA_EXPORT
  EMAIL_NOTIFICATION
  WEBHOOK_TRIGGER
  DATA_CLEANUP
  CUSTOM_SCRIPT
}

enum ScheduledTaskStatus {
  ACTIVE
  PAUSED
  DISABLED
  FAILED
}

enum TaskExecutionStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  CANCELLED
}

model ScheduledTask {
  id          String  @id @default(cuid())
  name        String
  description String?

  // Task configuration
  taskType ScheduledTaskType
  schedule String // Cron expression
  timezone String            @default("UTC")

  // Execution settings
  payload       Json? // Task-specific configuration
  timeout       Int   @default(300) // Seconds
  retryAttempts Int   @default(3)

  // Status
  status ScheduledTaskStatus @default(ACTIVE)

  // Next and last execution
  nextRunAt  DateTime?
  lastRunAt  DateTime?
  lastStatus TaskExecutionStatus?

  // Organization context
  organizationId String?
  organization   Organization? @relation("OrgScheduledTasks", fields: [organizationId], references: [id], onDelete: Cascade)

  // Execution logs
  executions ScheduledTaskExecution[] @relation("TaskExecutions")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([status])
  @@index([nextRunAt])
}

model ScheduledTaskExecution {
  id String @id @default(cuid())

  // Execution details
  status      TaskExecutionStatus @default(PENDING)
  startedAt   DateTime?
  completedAt DateTime?
  duration    Int? // Milliseconds

  // Results
  output       String? @db.Text
  errorMessage String? @db.Text

  // Attempt tracking
  attemptNumber Int @default(1)

  // Task reference
  taskId String
  task   ScheduledTask @relation("TaskExecutions", fields: [taskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
  @@index([status])
  @@index([startedAt])
}

// ============================================================
// Advanced Features - Custom Report Builder
// ============================================================

enum ReportOutputFormat {
  PDF
  EXCEL
  CSV
  HTML
  JSON
}

enum ReportScheduleFrequency {
  ONCE
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

model CustomReport {
  id          String  @id @default(cuid())
  name        String
  description String?

  // Report configuration
  dataSource   String // Main data model
  columns      Json // Selected columns/fields
  filters      Json? // Filter conditions
  groupBy      Json? // Grouping configuration
  sortBy       Json? // Sorting configuration
  aggregations Json? // Sum, avg, count, etc.

  // Visualization
  chartConfig Json? // Chart settings if visual

  // Output settings
  outputFormat     ReportOutputFormat @default(PDF)
  includeCharts    Boolean            @default(true)
  includeDataTable Boolean            @default(true)

  // Scheduling
  isScheduled       Boolean                  @default(false)
  scheduleFrequency ReportScheduleFrequency?
  scheduleCron      String?
  nextRunAt         DateTime?

  // Recipients for scheduled reports
  recipients String[] @default([])

  // Organization context
  organizationId String?
  organization   Organization? @relation("OrgCustomReports", fields: [organizationId], references: [id], onDelete: Cascade)

  // Execution history
  executions ReportExecution[] @relation("ReportExecutions")

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([isActive])
  @@index([nextRunAt])
}

model ReportExecution {
  id String @id @default(cuid())

  // Execution details
  status      TaskExecutionStatus @default(PENDING)
  startedAt   DateTime?
  completedAt DateTime?
  duration    Int? // Milliseconds

  // Output
  outputUrl    String? // URL to generated report
  fileSize     BigInt? // Bytes
  recordCount  Int?
  errorMessage String?

  // Report reference
  reportId String
  report   CustomReport @relation("ReportExecutions", fields: [reportId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reportId])
  @@index([status])
  @@index([startedAt])
}

// ============================================================
// Advanced Features - Advanced User Permissions
// ============================================================

enum PermissionAction {
  CREATE
  READ
  UPDATE
  DELETE
  APPROVE
  EXPORT
  MANAGE
  ALL
}

enum PermissionResource {
  PROJECT
  TASK
  DOCUMENT
  USER
  REPORT
  COST
  TIMESHEET
  RISK
  SAFETY
  EQUIPMENT
  SUBCONTRACTOR
  WEBHOOK
  BACKUP
  ANALYTICS
  SYSTEM_SETTINGS
  ALL
}

model Permission {
  id          String  @id @default(cuid())
  name        String
  description String?

  // Permission definition
  resource PermissionResource
  action   PermissionAction

  // Conditions (JSON for complex permission logic)
  conditions Json? // e.g., { "projectStatus": ["ACTIVE"], "ownerId": "$userId" }

  // System vs custom
  isSystem Boolean @default(false)

  // Grants
  grants PermissionGrant[] @relation("PermissionGrants")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([resource, action])
  @@index([resource])
  @@index([action])
}

model PermissionGrant {
  id String @id @default(cuid())

  // Permission reference
  permissionId String
  permission   Permission @relation("PermissionGrants", fields: [permissionId], references: [id], onDelete: Cascade)

  // Grant target (user or role)
  userId String?
  user   User?   @relation("UserPermissionGrants", fields: [userId], references: [id], onDelete: Cascade)

  role UserRole? // Grant to entire role

  // Scope limiting
  organizationId String?
  organization   Organization? @relation("OrgPermissionGrants", fields: [organizationId], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation("ProjectPermissionGrants", fields: [projectId], references: [id], onDelete: Cascade)

  // Expiry
  expiresAt DateTime?

  // Audit
  grantedById String?
  grantedBy   User?   @relation("GrantedPermissions", fields: [grantedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([permissionId])
  @@index([userId])
  @@index([organizationId])
  @@index([projectId])
  @@index([role])
}

// ============================================================
// Advanced Features - Organization Resource Quotas
// ============================================================

enum QuotaType {
  STORAGE
  USERS
  PROJECTS
  API_CALLS
  BACKUPS
  REPORTS
  WEBHOOKS
  CUSTOM
}

enum QuotaPeriod {
  DAILY
  MONTHLY
  YEARLY
  TOTAL
}

model ResourceQuota {
  id String @id @default(cuid())

  // Quota definition
  quotaType   QuotaType
  name        String
  description String?

  // Limits
  limitValue       BigInt // Max allowed
  warningThreshold Float       @default(0.8) // 80%
  period           QuotaPeriod @default(MONTHLY)

  // Organization context
  organizationId String
  organization   Organization @relation("OrgResourceQuotas", fields: [organizationId], references: [id], onDelete: Cascade)

  // Usage tracking
  usage QuotaUsageRecord[] @relation("QuotaUsage")

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, quotaType, period])
  @@index([organizationId])
  @@index([quotaType])
}

model QuotaUsageRecord {
  id String @id @default(cuid())

  // Usage details
  currentValue BigInt // Current usage
  timestamp    DateTime @default(now())

  // Period tracking
  periodStart DateTime
  periodEnd   DateTime

  // Quota reference
  quotaId String
  quota   ResourceQuota @relation("QuotaUsage", fields: [quotaId], references: [id], onDelete: Cascade)

  // Metadata
  metadata Json? // Additional context

  createdAt DateTime @default(now())

  @@index([quotaId])
  @@index([timestamp])
}

// ============================================================
// Advanced Features - API Rate Limiting
// ============================================================

model OrganizationRateLimit {
  id String @id @default(cuid())

  // Rate limit configuration
  endpoint          String? // Specific endpoint or "*" for all
  requestsPerMinute Int     @default(60)
  requestsPerHour   Int     @default(1000)
  requestsPerDay    Int     @default(10000)

  // Burst allowance
  burstSize Int @default(10)

  // Organization context
  organizationId String
  organization   Organization @relation("OrgRateLimits", fields: [organizationId], references: [id], onDelete: Cascade)

  // Usage tracking
  usage RateLimitUsage[] @relation("RateLimitUsage")

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, endpoint])
  @@index([organizationId])
}

model RateLimitUsage {
  id String @id @default(cuid())

  // Usage details
  endpoint     String
  requestCount Int      @default(1)
  windowStart  DateTime

  // Window type (minute, hour, day)
  windowType String // "minute", "hour", "day"

  // Rate limit reference
  rateLimitId String
  rateLimit   OrganizationRateLimit @relation("RateLimitUsage", fields: [rateLimitId], references: [id], onDelete: Cascade)

  // User context
  userId String?
  user   User?   @relation("UserRateLimitUsage", fields: [userId], references: [id], onDelete: SetNull)

  // Request metadata
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([rateLimitId])
  @@index([windowStart])
  @@index([endpoint])
  @@index([userId])
}

// ============================================================
// Advanced Features - Multi-Factor Authentication
// ============================================================

enum MFAType {
  TOTP
  SMS
  EMAIL
  BACKUP_CODE
}

enum MFAStatus {
  PENDING_SETUP
  ACTIVE
  DISABLED
  SUSPENDED
}

model UserMFA {
  id String @id @default(cuid())

  // MFA configuration
  mfaType MFAType
  status  MFAStatus @default(PENDING_SETUP)

  // TOTP secret (encrypted)
  secret String? // For TOTP

  // Phone number for SMS
  phoneNumber String? // For SMS

  // Backup codes (hashed)
  backupCodes String[] @default([])

  // Verification
  isVerified Boolean   @default(false)
  verifiedAt DateTime?

  // Usage tracking
  lastUsedAt DateTime?
  usageCount Int       @default(0)

  // User reference
  userId String
  user   User   @relation("UserMFAMethods", fields: [userId], references: [id], onDelete: Cascade)

  // Verification logs
  verificationLogs MFAVerificationLog[] @relation("MFAVerifications")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model MFAVerificationLog {
  id String @id @default(cuid())

  // Verification details
  mfaId String
  mfa   UserMFA @relation("MFAVerifications", fields: [mfaId], references: [id], onDelete: Cascade)

  // Result
  success Boolean
  method  MFAType

  // Request metadata
  ipAddress String?
  userAgent String?

  // Error info
  errorMessage String?

  timestamp DateTime @default(now())

  @@index([mfaId])
  @@index([timestamp])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Payroll management with CIS deductions (UK Construction Industry Scheme)
model Payroll {
  id             String        @id @default(cuid())
  employeeId     String        // User ID of the employee
  employee       TeamMember    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  period         String        // YYYY-MM format
  baseSalary     Float         // Base salary for the period
  overtime       Float         @default(0)
  cisDeduction   Float         // CIS deduction amount
  niContribution Float         @default(0) // National Insurance contribution
  pension        Float         @default(0) // Pension contribution
  netPay         Float         // Final net pay after all deductions
  status         PayrollStatus @default(DRAFT)
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId])
  @@index([employeeId])
  @@index([period])
  @@index([status])
}

enum PayrollStatus {
  DRAFT
  PROCESSED
  PAID
  CANCELLED
}

// Stripe subscription status
enum SubscriptionStatus {
  ACTIVE
  CANCELED
  INCOMPLETE
  INCOMPLETE_EXPIRED
  PAST_DUE
  PAUSED
  TRIALING
  UNPAID
}

model Subscription {
  id                    String             @id @default(cuid())
  stripeSubscriptionId  String?            @unique // Stripe subscription ID
  stripeCustomerId      String?            // Stripe customer ID
  organizationId        String
  organization          Organization       @relation(fields: [organizationId], references: [id])
  planId                String             // Internal plan ID (starter, professional, enterprise)
  status                SubscriptionStatus @default(ACTIVE)
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  cancelAtPeriodEnd     Boolean            @default(false)
  trialStart            DateTime?
  trialEnd              DateTime?
  quantity              Int                @default(1)
  metadata              Json?              // Store additional Stripe metadata
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  items                 SubscriptionItem[]

  @@index([organizationId])
  @@index([stripeSubscriptionId])
  @@index([status])
}

model Invoice {
  id                String       @id @default(cuid())
  stripeInvoiceId   String       @unique // Stripe invoice ID
  stripeCustomerId  String       // Stripe customer ID
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id])
  subscriptionId    String?      // Reference to subscription if applicable
  amountDue         Int          @default(0) // Amount due in cents
  amountPaid        Int          @default(0) // Amount paid in cents
  currency          String       @default("usd")
  status            String       // paid, open, uncollectible, void
  hostedInvoiceUrl  String?      // Stripe hosted invoice URL
  invoicePdf        String?      // Invoice PDF URL
  billingReason     String?      // subscription_cycle, subscription_create, etc.
  metadata          Json?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([organizationId])
  @@index([stripeInvoiceId])
  @@index([status])
}

model SubscriptionItem {
  id               String       @id @default(cuid())
  subscriptionId   String
  subscription     Subscription @relation(fields: [subscriptionId], references: [id])
  stripeItemId     String       @unique // Stripe subscription item ID
  stripePriceId    String       // Stripe price ID
  quantity         Int          @default(1)
  createdAt        DateTime     @default(now())

  @@index([subscriptionId])
}
