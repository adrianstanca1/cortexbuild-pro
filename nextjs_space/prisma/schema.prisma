// Enhanced Daily Report - Structured Material Entry
model DailyReportMaterial {
  id            String      @id @default(cuid())
  dailyReportId String
  dailyReport   DailyReport @relation("DailyReportMaterialEntries", fields: [dailyReportId], references: [id], onDelete: Cascade)

  // Material details
  materialName String
  materialCode String?

  // Quantities
  quantityReceived Float  @default(0)
  quantityUsed     Float  @default(0)
  unit             String @default("each")

