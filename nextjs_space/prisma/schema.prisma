// ============================================
// PHASE 1: ENTERPRISE CONSTRUCTION MANAGEMENT
// ============================================

// Project Phase for lifecycle management
enum ProjectPhase {
  PRECONSTRUCTION
  MOBILIZATION
  ACTIVE
  CLOSEOUT
  WARRANTY
}

// Work Package Status
enum WorkPackageStatus {
  DRAFT
  PLANNED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

// Work Packages - Middle layer between projects and tasks
model WorkPackage {
  id          String            @id @default(cuid())
  number      Int
  name        String
  description String?           @db.Text
  status      WorkPackageStatus @default(DRAFT)

  // Scope definition
  scope        String?  @db.Text
  deliverables String[] @default([])

  // Budget allocation
  budgetAmount    Float @default(0)
  committedAmount Float @default(0)
  actualAmount    Float @default(0)

  // Schedule
  plannedStartDate DateTime?
  plannedEndDate   DateTime?
  actualStartDate  DateTime?
  actualEndDate    DateTime?

  // Progress tracking
  percentComplete Int   @default(0) // 0-100
  weightage       Float @default(1) // For weighted progress

  // Responsible party
  responsiblePartyId String?
  responsibleParty   User?   @relation("WorkPackageResponsible", fields: [responsiblePartyId], references: [id])

  // Dependencies (Work Package IDs)
  predecessors   String[] @default([])
  successors     String[] @default([])
  dependencyType String? // FS, SS, FF, SF
  leadLagDays    Int      @default(0)

  // Critical path
  isCriticalPath Boolean @default(false)
  totalFloat     Int? // Days of float

  // Cost code linkage
  costCodeId String?
  costCode   CostCode? @relation(fields: [costCodeId], references: [id])

  // Project relation
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Audit
  createdById String
  createdBy   User   @relation("WorkPackageCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Related tasks inherit from this work package
  tasks Task[] @relation("WorkPackageTasks")

  // Production tracking entries
  productionLogs ProductionLog[]

  @@unique([projectId, number])
  @@index([projectId])
  @@index([status])
  @@index([costCodeId])
}

// Cost Code Hierarchy
model CostCode {
  id          String  @id @default(cuid())
  code        String // e.g., "01", "01.01", "01.01.001"
  name        String
  description String? @db.Text

  // Hierarchy
  parentId String?
  parent   CostCode?  @relation("CostCodeHierarchy", fields: [parentId], references: [id])
  children CostCode[] @relation("CostCodeHierarchy")
  level    Int        @default(1) // 1, 2, 3, etc.

  // Category mapping
  category CostCategory @default(OTHER)

  // Budget tracking
  budgetAmount    Float @default(0)
  committedAmount Float @default(0)
  actualAmount    Float @default(0)
  forecastAmount  Float @default(0)

  // Variance thresholds
  varianceThreshold Float @default(10) // Percentage

  // Status
  isActive Boolean @default(true)

  // Organization-level (shared library) or project-specific
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  // Project-specific override (null = organization library)
  projectId String?
  project   Project? @relation("ProjectCostCodes", fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  workPackages WorkPackage[]
  costItems    CostItem[]    @relation("CostCodeItems")
  budgetLines  BudgetLine[]

  @@unique([organizationId, code, projectId])
  @@index([organizationId])
  @@index([projectId])
  @@index([parentId])
  @@index([category])
}

// Budget Line Items (linked to cost codes)
model BudgetLine {
  id String @id @default(cuid())

  // Cost code linkage
  costCodeId String
  costCode   CostCode @relation(fields: [costCodeId], references: [id], onDelete: Cascade)

  // Project linkage
  projectId String
  project   Project @relation("ProjectBudgetLines", fields: [projectId], references: [id], onDelete: Cascade)

  // Budget values
  description    String?
  originalBudget Float   @default(0)
  revisedBudget  Float   @default(0)
  committed      Float   @default(0)
  actual         Float   @default(0)
  forecast       Float   @default(0)

  // Variance
  variance        Float @default(0)
  variancePercent Float @default(0)

  // Period tracking
  periodStart DateTime?
  periodEnd   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([costCodeId, projectId])
  @@index([projectId])
  @@index([costCodeId])
}

// Production Log - Quantity-based progress tracking
model ProductionLog {
  id String @id @default(cuid())

  // Date and shift
  date  DateTime @db.Date
  shift String? // Day, Night, etc.

  // Work package linkage
  workPackageId String
  workPackage   WorkPackage @relation(fields: [workPackageId], references: [id], onDelete: Cascade)

  // Quantity tracking
  unit               String // meters, units, sqm, etc.
  plannedQuantity    Float  @default(0)
  actualQuantity     Float  @default(0)
  cumulativeQuantity Float  @default(0)

  // Productivity metrics
  plannedProductivity Float? // Units per hour
  actualProductivity  Float?

  // Crew info
  crewSize  Int   @default(0)
  crewHours Float @default(0)

  // Weather impact
  weatherCondition String?
  weatherImpact    String? // None, Minor, Major, Work Stopped

  // Notes
  notes String? @db.Text

  // Recorded by
  recordedById String
  recordedBy   User   @relation("ProductionLogRecorder", fields: [recordedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workPackageId, date, shift])
  @@index([workPackageId])
  @@index([date])
}

// Change Order Version (for versioning)
model ChangeOrderVersion {
  id      String @id @default(cuid())
  version Int

  // Parent change order
  changeOrderId String
  changeOrder   ChangeOrder @relation("ChangeOrderVersions", fields: [changeOrderId], references: [id], onDelete: Cascade)

  // Snapshot of data at this version
  title          String
  description    String? @db.Text
  reason         String?
  costChange     Float   @default(0)
  scheduleChange Int?

  // Scope diff (JSON object showing what changed)
  scopeDiff Json?

  // Approval state at this version
  status ChangeOrderStatus @default(DRAFT)

  // Who created this version
  createdById String
  createdBy   User   @relation("ChangeOrderVersionCreator", fields: [createdById], references: [id])

  // Approval details
  approvedById     String?
  approvedBy       User?     @relation("ChangeOrderVersionApprover", fields: [approvedById], references: [id])
  approvedAt       DateTime?
  approvalComments String?   @db.Text

  createdAt DateTime @default(now())

  @@unique([changeOrderId, version])
  @@index([changeOrderId])
}

// Enhanced Daily Report - Structured Labor Entry
model DailyReportLabor {
