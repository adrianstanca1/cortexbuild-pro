// Forecast Entry for cost/schedule forecasting
model ForecastEntry {
  id String @id @default(cuid())

  // Project linkage
  projectId String
  project   Project @relation("ProjectForecasts", fields: [projectId], references: [id], onDelete: Cascade)

  // Forecast type
  forecastType String // COST, SCHEDULE, PRODUCTIVITY

  // Period
  forecastDate DateTime  @default(now())
  periodStart  DateTime?
  periodEnd    DateTime?

  // Cost forecasting
  originalBudget       Float?
  currentBudget        Float?
  actualToDate         Float?
  forecastAtCompletion Float? // FAC
  estimateToComplete   Float? // ETC
  varianceAtCompletion Float? // VAC

  // Schedule forecasting
  plannedDuration  Int? // Days
  actualDuration   Int?
  forecastDuration Int?
  scheduleVariance Int? // Days

  // Earned Value metrics
  plannedValue             Float? // BCWS
  earnedValue              Float? // BCWP
  actualCost               Float? // ACWP
  costPerformanceIndex     Float? // CPI
  schedulePerformanceIndex Float? // SPI

  // Confidence level
  confidence  String? // HIGH, MEDIUM, LOW
  assumptions String? @db.Text
  risks       String? @db.Text

  // Scenario tracking
  scenarioName String? // Best Case, Worst Case, Most Likely
  isBaseline   Boolean @default(false)

  // Created by
  createdById String
  createdBy   User   @relation("ForecastCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([forecastType])
  @@index([forecastDate])
}

// Risk Register
model RiskRegisterEntry {
  id     String @id @default(cuid())
  number Int

  // Project linkage
  projectId String
  project   Project @relation("ProjectRisks", fields: [projectId], references: [id], onDelete: Cascade)

  // Risk identification
  title       String
  description String  @db.Text
  category    String? // Technical, Financial, Schedule, Safety, etc.
  source      String? // Where identified

  // Risk assessment
  probability Int     @default(3) // 1-5
  impact      Int     @default(3) // 1-5
  riskScore   Int     @default(9) // probability x impact
  riskLevel   String? // LOW, MEDIUM, HIGH, CRITICAL

  // Dates
  identifiedDate DateTime  @default(now())
  reviewDate     DateTime?
  closedDate     DateTime?

  // Status
  status String @default("OPEN") // OPEN, MITIGATING, CLOSED, OCCURRED

  // Response
  responseStrategy String? // AVOID, MITIGATE, TRANSFER, ACCEPT
  mitigationPlan   String? @db.Text
  contingencyPlan  String? @db.Text

  // Cost/Schedule impact
  costImpactMin        Float?
  costImpactMax        Float?
  costImpactMostLikely Float?
  scheduleImpactDays   Int?

  // Owner
  ownerId String?
  owner   User?   @relation("RiskOwner", fields: [ownerId], references: [id])

  // Linked actions
  mitigationActions RiskAction[]

  // Trend tracking
  trendDirection String? // IMPROVING, STABLE, WORSENING
  previousScore  Int?

  // Audit
  createdById String
  createdBy   User   @relation("RiskCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, number])
  @@index([projectId])
  @@index([status])
  @@index([riskLevel])
}

// Risk Mitigation Actions
model RiskAction {
  id String @id @default(cuid())

  riskId String
  risk   RiskRegisterEntry @relation(fields: [riskId], references: [id], onDelete: Cascade)

  description   String    @db.Text
  dueDate       DateTime?
  status        String    @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  completedDate DateTime?

  // Assigned to
  assigneeId String?
  assignee   User?   @relation("RiskActionAssignee", fields: [assigneeId], references: [id])

  // Effectiveness
  effectiveness String? // EFFECTIVE, PARTIALLY_EFFECTIVE, INEFFECTIVE
  notes         String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([riskId])
  @@index([status])
}

// Executive Dashboard Snapshot (cached KPIs)
model DashboardSnapshot {
  id String @id @default(cuid())

  // Scope - organization or project level
  organizationId String
  organization   Organization @relation("OrgDashboardSnapshots", fields: [organizationId], references: [id])
  projectId      String?
  project        Project?     @relation("ProjectDashboardSnapshots", fields: [projectId], references: [id], onDelete: Cascade)

  // Snapshot timestamp
  snapshotDate DateTime @default(now())

  // Schedule KPIs
  scheduleVariance         Float? // Days
  schedulePerformanceIndex Float?
  projectsOnSchedule       Int?
  projectsDelayed          Int?

  // Cost KPIs
  costVariance         Float?
  costPerformanceIndex Float?
  totalBudget          Float?
  totalSpent           Float?
  forecastAtCompletion Float?

  // Risk KPIs
  openRisks     Int?
  highRisks     Int?
  criticalRisks Int?
  riskExposure  Float? // Total potential cost impact

  // Safety KPIs
  openIncidents      Int?
  incidentsThisMonth Int?
  nearMisses         Int?
  lostTimeInjuries   Int?

  // Change KPIs
  pendingChangeOrders  Int?
  approvedChangeOrders Int?
  changeOrderValue     Float?

  // Quality KPIs
  openDefects   Int?
  closedDefects Int?
  defectRate    Float?

  // Productivity KPIs
  plannedProgress   Float?
  actualProgress    Float?
  productivityIndex Float?

  // Raw data (JSON for flexibility)
  additionalMetrics Json?

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([projectId])
  @@index([snapshotDate])
}

