model SiteDiaryPhoto {
  id               String    @id @default(cuid())
  caption          String?
  cloudStoragePath String
  location         String? // Where on site
  siteDiaryId      String
  siteDiary        SiteDiary @relation(fields: [siteDiaryId], references: [id], onDelete: Cascade)
  createdAt        DateTime  @default(now())

  @@index([siteDiaryId])
}

// Defect/Snag List (Enhanced Punch List)
enum DefectStatus {
  IDENTIFIED
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  VERIFIED
  DISPUTED
}

enum DefectPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Defect {
  id               String         @id @default(cuid())
  number           Int
  title            String
  description      String?        @db.Text
  location         String? // Specific location
  floor            String? // Floor/level
  room             String? // Room/area
  trade            TradeType      @default(GENERAL)
  status           DefectStatus   @default(IDENTIFIED)
  priority         DefectPriority @default(MEDIUM)
  dueDate          DateTime?
  identifiedDate   DateTime       @default(now())
  completedDate    DateTime?
  verifiedDate     DateTime?
  responsibleParty String? // Who is responsible for fix
  rootCause        String?        @db.Text
  remedialAction   String?        @db.Text
  cost             Float? // Cost to fix
  projectId        String
  project          Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedToId     String?
  createdById      String
  verifiedById     String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
