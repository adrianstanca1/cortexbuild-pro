  @@index([claimId])
}

// ============================================
// TOOLBOX TALKS & DAILY CHECKS
// ============================================

enum ToolboxTalkStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum CheckStatus {
  PASS
  FAIL
  NEEDS_ATTENTION
  NOT_APPLICABLE
}

enum CheckItemResult {
  OK
  DEFECTIVE
  NEEDS_REPAIR
  NA
}

model ToolboxTalk {
  id          String            @id @default(cuid())
  title       String
  topic       String
  description String?           @db.Text
  date        DateTime
  startTime   DateTime?
  endTime     DateTime?
  location    String?
  status      ToolboxTalkStatus @default(SCHEDULED)

  // Content
  keyPoints        String[] @default([])
  hazardsDiscussed String[] @default([])
  safetyMeasures   String[] @default([])

  // Presenter info
  presenterId String
  presenter   User   @relation("ToolboxTalkPresenter", fields: [presenterId], references: [id])

  // Project relation
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Tracking
  notes             String? @db.Text
  weatherConditions String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Attendees with signatures
  attendees ToolboxTalkAttendee[]

  @@index([projectId])
  @@index([presenterId])
  @@index([date])
  @@index([status])
}

model ToolboxTalkAttendee {
  id            String      @id @default(cuid())
  toolboxTalkId String
  toolboxTalk   ToolboxTalk @relation(fields: [toolboxTalkId], references: [id], onDelete: Cascade)

  // Attendee info
  userId  String?
  user    User?   @relation("ToolboxTalkAttendance", fields: [userId], references: [id])
  name    String // For non-registered attendees
  company String?
  trade   String?

  // Signature tracking
  signedAt      DateTime?
  signatureData String?   @db.Text // Base64 encoded signature image
  signatureIp   String?

  acknowledged Boolean @default(false)

  createdAt DateTime @default(now())

  @@unique([toolboxTalkId, userId])
  @@index([toolboxTalkId])
  @@index([userId])
}

// MEWP (Mobile Elevating Work Platform) Daily Check
model MEWPCheck {
  id        String   @id @default(cuid())
  checkDate DateTime @default(now())

  // Equipment identification
  equipmentId     String?
  equipment       Equipment? @relation(fields: [equipmentId], references: [id])
  equipmentName   String
  equipmentSerial String?
  equipmentModel  String?
  manufacturer    String?

  // Location
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  location  String?

  // Operator info
  operatorId         String
  operator           User      @relation("MEWPOperator", fields: [operatorId], references: [id])
  operatorCertNumber String?
  certExpiryDate     DateTime?

  // Pre-use checks (all CheckItemResult)
  visualInspection      CheckItemResult @default(OK)
  guardrailsSecure      CheckItemResult @default(OK)
  floorCondition        CheckItemResult @default(OK)
  controlsFunction      CheckItemResult @default(OK)
  emergencyControls     CheckItemResult @default(OK)
  wheelsAndTyres        CheckItemResult @default(OK)
  outriggersStabilizers CheckItemResult @default(OK)
  hydraulicSystem       CheckItemResult @default(OK)
  electricalSystem      CheckItemResult @default(OK)
  safetyDevices         CheckItemResult @default(OK)
  warningAlarms         CheckItemResult @default(OK)
  manualOverride        CheckItemResult @default(OK)
  loadPlateVisible      CheckItemResult @default(OK)
  userManualPresent     CheckItemResult @default(OK)

  // Overall status
  overallStatus CheckStatus @default(PASS)
  isSafeToUse   Boolean     @default(true)

  // Comments and defects
  defectsFound String? @db.Text
  actionsTaken String? @db.Text
  comments     String? @db.Text

  // Signature tracking
  operatorSignature   String?   @db.Text // Base64 encoded signature
  operatorSignedAt    DateTime?
  supervisorId        String?
  supervisor          User?     @relation("MEWPSupervisor", fields: [supervisorId], references: [id])
  supervisorSignature String?   @db.Text
  supervisorSignedAt  DateTime?

  // Weather conditions
  weatherConditions String?
  windSpeed         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([equipmentId])
  @@index([operatorId])
  @@index([checkDate])
  @@index([overallStatus])
}

// Tool Daily Check
model ToolCheck {
  id        String   @id @default(cuid())
  checkDate DateTime @default(now())

  // Tool identification
  toolName     String
  toolType     String // Power Tool, Hand Tool, Ladder, etc.
  toolSerial   String?
  toolAssetTag String?
  manufacturer String?

  // Location
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  location  String?

  // Inspector info
  inspectorId String
  inspector   User   @relation("ToolInspector", fields: [inspectorId], references: [id])

  // Inspection items (varies by tool type)
  generalCondition   CheckItemResult @default(OK)
  cableCondition     CheckItemResult @default(NA) // For power tools
  plugCondition      CheckItemResult @default(NA) // For power tools
  guardsFunctional   CheckItemResult @default(NA) // For power tools
  switchesFunctional CheckItemResult @default(OK)
  handlesSecure      CheckItemResult @default(OK)
  bladeSharpness     CheckItemResult @default(NA) // For cutting tools
  lubricationStatus  CheckItemResult @default(NA)
  safetyFeatures     CheckItemResult @default(OK)
  storageCondition   CheckItemResult @default(OK)
  patTestCurrent     CheckItemResult @default(NA) // PAT test status

  // For ladders specifically
  stileCondition     CheckItemResult @default(NA)
  rungCondition      CheckItemResult @default(NA)
  feetCondition      CheckItemResult @default(NA)
  lockingMechanismOk CheckItemResult @default(NA)

  // Overall status
  overallStatus     CheckStatus @default(PASS)
  isSafeToUse       Boolean     @default(true)
  nextInspectionDue DateTime?

  // Comments and defects
  defectsFound String? @db.Text
  actionsTaken String? @db.Text
  comments     String? @db.Text

  // Signature tracking
  inspectorSignature String?   @db.Text
  inspectorSignedAt  DateTime?

  // Photo evidence
  photoUrls String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([inspectorId])
  @@index([checkDate])
  @@index([toolType])
  @@index([overallStatus])
}

// ============================================
// ENHANCED CONSTRUCTION FEATURES
// ============================================

// Risk Assessment Status
enum RAMSStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  SUPERSEDED
}

// Risk Assessment / Method Statement (RAMS)
model RiskAssessment {
  id       String     @id @default(cuid())
  number   Int
  title    String
  revision String     @default("A")
  status   RAMSStatus @default(DRAFT)

  // Activity details
  activityDescription String    @db.Text
  location            String?
  startDate           DateTime?
  endDate             DateTime?

  // Hazard identification
  hazards RiskHazard[]

  // Method statement
  methodStatement String?  @db.Text
  sequence        String[] @default([]) // Step-by-step work sequence

  // Required PPE
  requiredPPE String[] @default([])

  // Emergency procedures
  emergencyProcedures String? @db.Text
  nearestFirstAid     String?
  assemblyPoint       String?

  // Project relation
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Approval workflow
  createdById    String
  createdBy      User      @relation("RAMSCreator", fields: [createdById], references: [id])
  reviewedById   String?
  reviewedBy     User?     @relation("RAMSReviewer", fields: [reviewedById], references: [id])
  approvedById   String?
  approvedBy     User?     @relation("RAMSApprover", fields: [approvedById], references: [id])
  approvedDate   DateTime?
  reviewComments String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Workers who acknowledged
  acknowledgements RAMSAcknowledgement[]

  @@unique([projectId, number, revision])
  @@index([projectId])
  @@index([status])
}

// Individual hazard within a risk assessment
model RiskHazard {
  id               String         @id @default(cuid())
  riskAssessmentId String
  riskAssessment   RiskAssessment @relation(fields: [riskAssessmentId], references: [id], onDelete: Cascade)

  hazardDescription String   @db.Text
  personsAtRisk     String[] @default([]) // Workers, public, visitors

  // Risk rating before controls
  initialSeverity   Int @default(3) // 1-5
  initialLikelihood Int @default(3) // 1-5
  initialRiskScore  Int @default(9) // Severity x Likelihood

  // Control measures
  controlMeasures String[] @default([])

  // Risk rating after controls
  residualSeverity   Int @default(1)
  residualLikelihood Int @default(1)
  residualRiskScore  Int @default(1)

  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([riskAssessmentId])
}

// Worker acknowledgement of RAMS
model RAMSAcknowledgement {
  id               String         @id @default(cuid())
  riskAssessmentId String
  riskAssessment   RiskAssessment @relation(fields: [riskAssessmentId], references: [id], onDelete: Cascade)

  workerId   String?
  worker     User?   @relation("RAMSAcknowledger", fields: [workerId], references: [id])
  workerName String // For non-registered workers
  company    String?

  acknowledgedAt DateTime @default(now())
  signatureData  String?  @db.Text
  signatureIp    String?

  @@unique([riskAssessmentId, workerId])
  @@index([riskAssessmentId])
}

// Permit to Work Status
enum PermitToWorkStatus {
  REQUESTED
  APPROVED
  ACTIVE
  COMPLETED
  CANCELLED
  EXPIRED
}

// Hot Work Permit
model HotWorkPermit {
  id     String             @id @default(cuid())
  number Int
  status PermitToWorkStatus @default(REQUESTED)

  // Work details
  workDescription String  @db.Text
  location        String
  floor           String?
  equipment       String? // Welding machine, grinder, etc.

  // Time validity
  validFrom DateTime
  validTo   DateTime

  // Pre-work checks
  fireExtinguisherAvailable Boolean @default(false)
  areaCleared               Boolean @default(false)
  combustiblesRemoved       Boolean @default(false)
  fireWatchAssigned         Boolean @default(false)
  sprinklersOperational     Boolean @default(true)
  detectorsIsolated         Boolean @default(false)
  ventilationAdequate       Boolean @default(false)

  // Fire watch details
  fireWatchName     String?
  fireWatchDuration Int? // Minutes after work

  // Project relation
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Personnel
  requestedById String
  requestedBy   User    @relation("HotWorkRequester", fields: [requestedById], references: [id])
  approvedById  String?
  approvedBy    User?   @relation("HotWorkApprover", fields: [approvedById], references: [id])

  // Signatures
  requesterSignature String?   @db.Text
  requesterSignedAt  DateTime?
  approverSignature  String?   @db.Text
  approverSignedAt   DateTime?

  // Completion
  completedById       String?
  completedBy         User?     @relation("HotWorkCompleter", fields: [completedById], references: [id])
  completedAt         DateTime?
  completionNotes     String?   @db.Text
  completionSignature String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, number])
  @@index([projectId])
  @@index([status])
  @@index([validFrom])
}

// Confined Space Entry Permit
model ConfinedSpacePermit {
  id     String             @id @default(cuid())
  number Int
  status PermitToWorkStatus @default(REQUESTED)

  // Space identification
  spaceDescription String @db.Text
  location         String
  reasonForEntry   String @db.Text

  // Time validity
  validFrom DateTime
  validTo   DateTime

  // Atmosphere testing
  oxygenLevel     Float? // %
  h2sLevel        Float? // ppm
  coLevel         Float? // ppm
  lelLevel        Float? // % LEL (Lower Explosive Limit)
  testDateTime    DateTime?
  testPerformedBy String?

  // Pre-entry checks
  spaceLocked          Boolean @default(false)
  spaceIsolated        Boolean @default(false)
  ventilationProvided  Boolean @default(false)
  lightingProvided     Boolean @default(false)
  communicationTested  Boolean @default(false)
  rescueEquipmentReady Boolean @default(false)
  entrantsTrained      Boolean @default(false)

  // Personnel assignments
  entrantNames       String[] @default([])
  attendantName      String?
  rescueTeamNotified Boolean  @default(false)

  // Emergency
  emergencyContact String?
  emergencyNumber  String?
  nearestHospital  String?

  // Project relation
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Personnel
  requestedById String
  requestedBy   User    @relation("CSRequester", fields: [requestedById], references: [id])
  approvedById  String?
  approvedBy    User?   @relation("CSApprover", fields: [approvedById], references: [id])

  // Signatures
  requesterSignature String?   @db.Text
  requesterSignedAt  DateTime?
  approverSignature  String?   @db.Text
  approverSignedAt   DateTime?
  attendantSignature String?   @db.Text
  attendantSignedAt  DateTime?

  // Completion
  completedAt     DateTime?
  completionNotes String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, number])
  @@index([projectId])
  @@index([status])
}

// Lifting Operation Status
