generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
  output        = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  COMPANY_OWNER
  ADMIN
  PROJECT_MANAGER
  FIELD_WORKER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  ARCHIVED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  COMPLETE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum DocumentType {
  PLANS
  DRAWINGS
  PERMITS
  PHOTOS
  REPORTS
  SPECIFICATIONS
  CONTRACTS
  OTHER
}

model Organization {
  id                   String                  @id @default(cuid())
  name                 String
  slug                 String                  @unique
  logoUrl              String?
  // Onboarding fields
  industry             String?
  size                 String?
  description          String?
  plan                 String?                 @default("starter")
  onboardingStatus     String                  @default("NOT_STARTED")
  onboardingCurrentStep Int                    @default(0)
  // Entitlements - JSON object defining enabled modules and limits
  entitlements         Json?                   @default("{\"modules\":{\"projects\":true,\"tasks\":true,\"documents\":true,\"rfis\":true,\"submittals\":true,\"changeOrders\":true,\"dailyReports\":true,\"safety\":true,\"reports\":true,\"team\":true},\"limits\":{\"storageGB\":10,\"maxUsers\":50,\"maxProjects\":100}}")
  storageUsedBytes     BigInt                  @default(0)
  isActive             Boolean                 @default(true)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  users                User[]
  projects             Project[]
  teamMembers          TeamMember[]
  invitations          CompanyInvitation[]
  teamInvitations      TeamInvitation[]        @relation("TeamInvitations")
  equipment            Equipment[]
  webhooks             Webhook[]
  subcontractors       Subcontractor[]
  workerCertifications WorkerCertification[]
  // Phase 1-3 enterprise features
  costCodes            CostCode[]
  dashboardSnapshots   DashboardSnapshot[]     @relation("OrgDashboardSnapshots")
  automationRules      AutomationRule[]        @relation("OrgAutomationRules")
  predictiveSignals    PredictiveSignal[]      @relation("OrgPredictiveSignals")
  documentTemplates    DocumentTemplate[]
  // Advanced features relations
  analyticsWidgets     AnalyticsWidget[]       @relation("OrgAnalyticsWidgets")
  analyticsDashboards  AnalyticsDashboard[]    @relation("OrgAnalyticsDashboards")
  backupConfigs        BackupConfiguration[]   @relation("OrgBackupConfigs")
  backupRecords        BackupRecord[]          @relation("OrgBackupRecords")
  scheduledTasks       ScheduledTask[]         @relation("OrgScheduledTasks")
  customReports        CustomReport[]          @relation("OrgCustomReports")
  permissionGrants     PermissionGrant[]       @relation("OrgPermissionGrants")
  resourceQuotas       ResourceQuota[]         @relation("OrgResourceQuotas")
  rateLimits           OrganizationRateLimit[] @relation("OrgRateLimits")
  // Payroll relations
  payrollRecords       Payroll[]
  // Stripe billing relations
  subscriptions        Subscription[]
  invoices             Invoice[]
}

model CompanyInvitation {
  id             String           @id @default(cuid())
  token          String           @unique @default(cuid())
  companyName    String
  ownerName      String
  ownerEmail     String
  ownerPhone     String?
  status         InvitationStatus @default(PENDING)
  // Snapshot of entitlements at invitation time
  entitlements   Json
  expiresAt      DateTime
  acceptedAt     DateTime?
  // Created organization after acceptance
  organizationId String?
  organization   Organization?    @relation(fields: [organizationId], references: [id])
  // Audit fields
  invitedById    String
  invitedBy      User             @relation("InvitationCreator", fields: [invitedById], references: [id])
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([token])
  @@index([ownerEmail])
  @@index([status])
}

model User {
  emailVerified               DateTime?
  accounts                    Account[]
  sessions                    Session[]
  id                          String                    @id @default(cuid())
  email                       String                    @unique
  password                    String?
  name                        String
  role                        UserRole                  @default(FIELD_WORKER)
  avatarUrl                   String?
  phone                       String?
  organizationId              String?
  organization                Organization?             @relation(fields: [organizationId], references: [id])
  createdAt                   DateTime                  @default(now())
  updatedAt                   DateTime                  @updatedAt
  lastLogin                   DateTime?
  managedProjects             Project[]                 @relation("ProjectManager")
  assignedTasks               Task[]                    @relation("TaskAssignee")
  createdTasks                Task[]                    @relation("TaskCreator")
  uploadedDocs                Document[]                @relation("DocumentUploader")
  activities                  ActivityLog[]
  notifications               Notification[]
  taskComments                TaskComment[]
  teamMemberships             TeamMember[]
  // Construction management relations
  createdRFIs                 RFI[]                     @relation("RFICreator")
  assignedRFIs                RFI[]                     @relation("RFIAssignee")
  answeredRFIs                RFI[]                     @relation("RFIAnswerer")
  submittedSubmittals         Submittal[]               @relation("SubmittalSubmitter")
  reviewedSubmittals          Submittal[]               @relation("SubmittalReviewer")
  requestedCOs                ChangeOrder[]             @relation("ChangeOrderRequester")
  approvedCOs                 ChangeOrder[]             @relation("ChangeOrderApprover")
  dailyReports                DailyReport[]             @relation("DailyReportCreator")
  reportedIncidents           SafetyIncident[]          @relation("IncidentReporter")
  assignedIncidents           SafetyIncident[]          @relation("IncidentInvestigator")
  createdInvitations          CompanyInvitation[]       @relation("InvitationCreator")
  createdTeamInvitations      TeamInvitation[]          @relation("TeamInvitationCreator")
  // Additional construction module relations
  assignedPunchLists          PunchList[]               @relation("PunchListAssignee")
  createdPunchLists           PunchList[]               @relation("PunchListCreator")
  verifiedPunchLists          PunchList[]               @relation("PunchListVerifier")
  maintenancePerformed        EquipmentMaintenanceLog[] @relation("MaintenancePerformer")
  equipmentCheckouts          EquipmentUsageLog[]       @relation("EquipmentCheckOut")
  requestedInspections        Inspection[]              @relation("InspectionRequester")
  organizedMeetings           MeetingMinutes[]          @relation("MeetingOrganizer")
  webhooksCreated             Webhook[]                 @relation("WebhookCreator")
  // API Management relations
  apiConnectionsCreated       ApiConnection[]           @relation("ApiConnectionCreator")
  apiConnectionsModified      ApiConnection[]           @relation("ApiConnectionModifier")
  apiConnectionLogs           ApiConnectionLog[]        @relation("ApiConnectionAuditor")
  // Advanced construction module relations
  createdCostItems            CostItem[]                @relation("CostItemCreator")
  createdMaterials            Material[]                @relation("MaterialCreator")
  receivedDeliveries          MaterialDelivery[]        @relation("MaterialReceiver")
  createdMilestones           Milestone[]               @relation("MilestoneCreator")
  // Time tracking relations
  timeEntries                 TimeEntry[]               @relation("UserTimeEntries")
  approvedTimeEntries         TimeEntry[]               @relation("ApprovedTimeEntries")
  // Toolbox talks and daily checks relations
  presentedToolboxTalks       ToolboxTalk[]             @relation("ToolboxTalkPresenter")
  toolboxTalkAttendance       ToolboxTalkAttendee[]     @relation("ToolboxTalkAttendance")
  mewpChecksAsOperator        MEWPCheck[]               @relation("MEWPOperator")
  mewpChecksAsSupervisor      MEWPCheck[]               @relation("MEWPSupervisor")
  toolChecks                  ToolCheck[]               @relation("ToolInspector")
  // Enhanced construction features relations
  createdRAMS                 RiskAssessment[]          @relation("RAMSCreator")
  reviewedRAMS                RiskAssessment[]          @relation("RAMSReviewer")
  approvedRAMS                RiskAssessment[]          @relation("RAMSApprover")
  ramsAcknowledgements        RAMSAcknowledgement[]     @relation("RAMSAcknowledger")
  requestedHotWorkPermits     HotWorkPermit[]           @relation("HotWorkRequester")
  approvedHotWorkPermits      HotWorkPermit[]           @relation("HotWorkApprover")
  completedHotWorkPermits     HotWorkPermit[]           @relation("HotWorkCompleter")
  requestedCSPermits          ConfinedSpacePermit[]     @relation("CSRequester")
  approvedCSPermits           ConfinedSpacePermit[]     @relation("CSApprover")
  plannedLifts                LiftingOperation[]        @relation("LiftPlanner")
  operatedLifts               LiftingOperation[]        @relation("LiftOperator")
  supervisedLifts             LiftingOperation[]        @relation("LiftSupervisor")
  appointedPersonLifts        LiftingOperation[]        @relation("LiftAppointedPerson")
  certifications              WorkerCertification[]     @relation("WorkerCerts")
  verifiedCertifications      WorkerCertification[]     @relation("CertVerifier")
  siteAccessLogs              SiteAccessLog[]           @relation("UserSiteAccess")
  recordedAccessLogs          SiteAccessLog[]           @relation("AccessRecorder")
  // Phase 1-3 enterprise features
  responsibleWorkPackages     WorkPackage[]             @relation("WorkPackageResponsible")
  createdWorkPackages         WorkPackage[]             @relation("WorkPackageCreator")
  productionLogs              ProductionLog[]           @relation("ProductionLogRecorder")
  changeOrderVersionsCreated  ChangeOrderVersion[]      @relation("ChangeOrderVersionCreator")
  changeOrderVersionsApproved ChangeOrderVersion[]      @relation("ChangeOrderVersionApprover")
  forecastsCreated            ForecastEntry[]           @relation("ForecastCreator")
  ownedRisks                  RiskRegisterEntry[]       @relation("RiskOwner")
  createdRisks                RiskRegisterEntry[]       @relation("RiskCreator")
  assignedRiskActions         RiskAction[]              @relation("RiskActionAssignee")
  automationRulesCreated      AutomationRule[]          @relation("AutomationRuleCreator")
  acknowledgedSignals         PredictiveSignal[]        @relation("SignalAcknowledger")
  vendorAccessCreated         VendorPortalAccess[]      @relation("VendorAccessCreator")
  vendorSubmissionsReviewed   VendorSubmission[]        @relation("VendorSubmissionReviewer")
  createdTemplates            DocumentTemplate[]        @relation("TemplateCreator")
  // Drawing management relations
  uploadedDrawingRevisions    DrawingRevision[]
  drawingAnnotations          DrawingAnnotation[]
  // Advanced features relations
  permissionGrants            PermissionGrant[]         @relation("UserPermissionGrants")
  grantedPermissions          PermissionGrant[]         @relation("GrantedPermissions")
  mfaMethods                  UserMFA[]                 @relation("UserMFAMethods")
  rateLimitUsage              RateLimitUsage[]          @relation("UserRateLimitUsage")
  // RAMS and Variations relations
  createdRAMSDocuments        RAMSDocument[]            @relation("RAMSCreator")
  createdVariations           Variation[]               @relation("VariationCreator")
  // Audit log relation
  auditLogs                   AuditLog[]                @relation("AuditLogUser")
}

model Project {
  id                   String                  @id @default(cuid())
  name                 String
  description          String?
  status               ProjectStatus           @default(PLANNING)
  location             String?
  clientName           String?
  clientEmail          String?
  budget               Float?
  startDate            DateTime?
  endDate              DateTime?
  organizationId       String
  organization         Organization            @relation(fields: [organizationId], references: [id])
  managerId            String?
  manager              User?                   @relation("ProjectManager", fields: [managerId], references: [id])
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  tasks                Task[]
  documents            Document[]
  teamMembers          ProjectTeamMember[]
  activities           ActivityLog[]
  notifications        Notification[]
  // Construction management relations
  rfis                 RFI[]
  submittals           Submittal[]
  changeOrders         ChangeOrder[]
  dailyReports         DailyReport[]
  safetyIncidents      SafetyIncident[]
  // Additional construction modules
  punchLists           PunchList[]
  equipment            Equipment[]             @relation("EquipmentProject")
  equipmentUsage       EquipmentUsageLog[]
  inspections          Inspection[]
  meetings             MeetingMinutes[]
  // Advanced construction modules
  costItems            CostItem[]
  materials            Material[]
  subcontracts         SubcontractorContract[]
  milestones           Milestone[]
  weatherLogs          WeatherLog[]
  timeEntries          TimeEntry[]
  // New construction modules
  permits              Permit[]
  drawings             Drawing[]
  siteDiaries          SiteDiary[]
  defects              Defect[]
  progressClaims       ProgressClaim[]
  // Toolbox talks and daily checks
  toolboxTalks         ToolboxTalk[]
  mewpChecks           MEWPCheck[]
  toolChecks           ToolCheck[]
  // Enhanced construction features
  riskAssessments      RiskAssessment[]
  hotWorkPermits       HotWorkPermit[]
  confinedSpacePermits ConfinedSpacePermit[]
  liftingOperations    LiftingOperation[]
  siteAccessLogs       SiteAccessLog[]
  // Phase 1-3 enterprise features
  phase                ProjectPhase            @default(PRECONSTRUCTION)
  workPackages         WorkPackage[]
  costCodes            CostCode[]              @relation("ProjectCostCodes")
  budgetLines          BudgetLine[]            @relation("ProjectBudgetLines")
  forecasts            ForecastEntry[]         @relation("ProjectForecasts")
  riskRegister         RiskRegisterEntry[]     @relation("ProjectRisks")
  dashboardSnapshots   DashboardSnapshot[]     @relation("ProjectDashboardSnapshots")
  automationRules      AutomationRule[]        @relation("ProjectAutomationRules")
  predictiveSignals    PredictiveSignal[]      @relation("ProjectPredictiveSignals")
  vendorSubmissions    VendorSubmission[]      @relation("ProjectVendorSubmissions")
  // Advanced features relations
  permissionGrants     PermissionGrant[]       @relation("ProjectPermissionGrants")
  // RAMS and Variations relations
  ramsDocuments        RAMSDocument[]
  variations           Variation[]
}

model Task {
  id            String        @id @default(cuid())
  title         String
  description   String?
  status        TaskStatus    @default(TODO)
  priority      TaskPriority  @default(MEDIUM)
  dueDate       DateTime?
  completedAt   DateTime?
  projectId     String
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assigneeId    String?
  assignee      User?         @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creatorId     String?
  creator       User?         @relation("TaskCreator", fields: [creatorId], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  comments      TaskComment[]
  timeEntries   TimeEntry[]
  // Work Package inheritance
  workPackageId String?
  workPackage   WorkPackage?  @relation("WorkPackageTasks", fields: [workPackageId], references: [id], onDelete: SetNull)
}

model TaskComment {
  id        String   @id @default(cuid())
  content   String
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
}

model TeamMember {
  id                 String              @id @default(cuid())
  userId             String
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId     String
  organization       Organization        @relation(fields: [organizationId], references: [id])
  jobTitle           String?
  department         String?
  invitedAt          DateTime            @default(now())
  projectAssignments ProjectTeamMember[]
  // Payroll relations
  payrollRecords     Payroll[]

  @@unique([userId, organizationId])
}

model ProjectTeamMember {
  id           String     @id @default(cuid())
  projectId    String
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  teamMemberId String
  teamMember   TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  assignedAt   DateTime   @default(now())

  @@unique([projectId, teamMemberId])
}

// Team member invitation (Company Owner invites team members)
model TeamInvitation {
  id             String           @id @default(cuid())
  token          String           @unique @default(cuid())
  email          String
  name           String
  role           UserRole         @default(FIELD_WORKER)
  jobTitle       String?
  department     String?
  status         InvitationStatus @default(PENDING)
  organizationId String
  organization   Organization     @relation("TeamInvitations", fields: [organizationId], references: [id])
  invitedById    String
  invitedBy      User             @relation("TeamInvitationCreator", fields: [invitedById], references: [id])
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([token])
  @@index([email])
  @@index([organizationId])
}

model Document {
  id               String       @id @default(cuid())
  name             String
  documentType     DocumentType @default(OTHER)
  cloudStoragePath String
  isPublic         Boolean      @default(false)
  fileSize         Int?
  mimeType         String?
  projectId        String
  project          Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedById     String
  uploadedBy       User         @relation("DocumentUploader", fields: [uploadedById], references: [id])
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model ActivityLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String?
  entityName String?
  details    String?
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  projectId  String?
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
}

// Comprehensive AuditLog for construction features
model AuditLog {
  id         String   @id @default(cuid())
  entity     String   // Entity type (Variation, DailyReport, Payroll, RiskAssessment, ToolboxTalk, MEWPCheck)
  entityId   String   // ID of the affected entity
  action     String   // CREATE, UPDATE, DELETE, STATUS_CHANGE
  userId     String
  user       User     @relation(fields: [userId], references: [id], map: "AuditLog_userId", name: "AuditLogUser")
  oldValues  Json?    // Snapshot of values before change
  newValues  Json?    // Snapshot of values after change
  changes    Json?    // Detailed field changes { field: { old, new } }
  timestamp  DateTime @default(now())
  ipAddress  String?
  userAgent  String?
  metadata   Json?    // Additional context (projectId, organizationId, etc.)
  createdAt  DateTime @default(now())

  @@index([entity])
  @@index([entityId])
  @@index([userId])
  @@index([action])
  @@index([timestamp])
  @@index([entity, timestamp])
}

enum NotificationType {
  INFO
  WARNING
  ERROR
  SUCCESS
  TASK_ASSIGNED
  TASK_UPDATED
  TASK_COMPLETED
  PROJECT_MESSAGE
  RFI_RESPONSE
  SUBMITTAL_APPROVED
  SUBMITTAL_REJECTED
  DEADLINE_REMINDER
  SAFETY_INCIDENT
  SYSTEM_ALERT
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  projectId String?
  project   Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  title     String
  message   String
  type      NotificationType @default(INFO)
  data      Json?
  read      Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([projectId])
  @@index([read])
  @@index([createdAt])
  @@index([userId, read, createdAt])
}

// =====================
// CONSTRUCTION MANAGEMENT MODULES
// =====================

enum RFIStatus {
  DRAFT
  OPEN
  ANSWERED
  CLOSED
}

enum SubmittalStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  REVISE_RESUBMIT
}

enum ChangeOrderStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  EXECUTED
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  CLOSED
}

enum WeatherCondition {
  SUNNY
  CLOUDY
  RAINY
  STORMY
  SNOWY
  WINDY
}

model RFI {
  id             String          @id @default(cuid())
  number         Int
  subject        String
  question       String          @db.Text
  answer         String?         @db.Text
  status         RFIStatus       @default(DRAFT)
  dueDate        DateTime?
  ballInCourt    String?
  specSection    String?
  drawingRef     String?
  costImpact     Boolean         @default(false)
  scheduleImpact Boolean         @default(false)
  projectId      String
  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User            @relation("RFICreator", fields: [createdById], references: [id])
  assignedToId   String?
  assignedTo     User?           @relation("RFIAssignee", fields: [assignedToId], references: [id])
  answeredById   String?
  answeredBy     User?           @relation("RFIAnswerer", fields: [answeredById], references: [id])
  answeredAt     DateTime?
  closedAt       DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  attachments    RFIAttachment[]

  @@unique([projectId, number])
}

model RFIAttachment {
  id               String   @id @default(cuid())
  name             String
  cloudStoragePath String
  fileSize         Int?
  mimeType         String?
  rfiId            String
  rfi              RFI      @relation(fields: [rfiId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
}

model Submittal {
  id             String                @id @default(cuid())
  number         Int
  title          String
  description    String?               @db.Text
  status         SubmittalStatus       @default(DRAFT)
  specSection    String?
  dueDate        DateTime?
  submittedAt    DateTime?
  reviewedAt     DateTime?
  revisionNumber Int                   @default(0)
  reviewComments String?               @db.Text
  projectId      String
  project        Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  submittedById  String?
  submittedBy    User?                 @relation("SubmittalSubmitter", fields: [submittedById], references: [id])
  reviewedById   String?
  reviewedBy     User?                 @relation("SubmittalReviewer", fields: [reviewedById], references: [id])
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  attachments    SubmittalAttachment[]

  @@unique([projectId, number])
}

model SubmittalAttachment {
  id               String    @id @default(cuid())
  name             String
  cloudStoragePath String
  fileSize         Int?
  mimeType         String?
  version          Int       @default(1)
  submittalId      String
  submittal        Submittal @relation(fields: [submittalId], references: [id], onDelete: Cascade)
  createdAt        DateTime  @default(now())
}

model ChangeOrder {
  id             String               @id @default(cuid())
  number         Int
  title          String
  description    String?              @db.Text
  status         ChangeOrderStatus    @default(DRAFT)
  reason         String?
  costChange     Float                @default(0)
  scheduleChange Int? // Days added/removed
  originalBudget Float?
  revisedBudget  Float?
  projectId      String
  project        Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requestedById  String
  requestedBy    User                 @relation("ChangeOrderRequester", fields: [requestedById], references: [id])
  approvedById   String?
  approvedBy     User?                @relation("ChangeOrderApprover", fields: [approvedById], references: [id])
  approvedAt     DateTime?
  executedAt     DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  // Version tracking for audit trail
  currentVersion Int                  @default(1)
  versions       ChangeOrderVersion[] @relation("ChangeOrderVersions")

  @@unique([projectId, number])
}

// Variation/Change Order (simplified for bill-master integration)
model Variation {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  total       Float    @default(0)
  status      VariationStatus @default(PENDING)
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User     @relation("VariationCreator", fields: [createdById], references: [id])
  approvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum VariationStatus {
  PENDING
  APPROVED
  REJECTED
}

model DailyReport {
  id               String                 @id @default(cuid())
  reportDate       DateTime               @db.Date
  weather          WeatherCondition       @default(SUNNY)
  temperature      Int? // Fahrenheit
  workPerformed    String?                @db.Text
  materialsUsed    String?                @db.Text
  equipmentUsed    String?                @db.Text
  visitors         String?
  delays           String?                @db.Text
  safetyNotes      String?                @db.Text
  manpowerCount    Int                    @default(0)
  projectId        String
  project          Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdById      String
  createdBy        User                   @relation("DailyReportCreator", fields: [createdById], references: [id])
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  photos           DailyReportPhoto[]
  // Structured entries for Phase 1 enhancement
  laborEntries     DailyReportLabor[]     @relation("DailyReportLaborEntries")
  equipmentEntries DailyReportEquipment[] @relation("DailyReportEquipmentEntries")
  materialEntries  DailyReportMaterial[]  @relation("DailyReportMaterialEntries")

  @@unique([projectId, reportDate])
}

model DailyReportPhoto {
  id               String      @id @default(cuid())
  caption          String?
  cloudStoragePath String
  dailyReportId    String
  dailyReport      DailyReport @relation(fields: [dailyReportId], references: [id], onDelete: Cascade)
  createdAt        DateTime    @default(now())
}

model SafetyIncident {
  id                String                @id @default(cuid())
  incidentDate      DateTime
  location          String?
  description       String                @db.Text
  severity          IncidentSeverity      @default(MEDIUM)
  status            IncidentStatus        @default(OPEN)
  injuryOccurred    Boolean               @default(false)
  injuryDescription String?               @db.Text
  rootCause         String?               @db.Text
  correctiveAction  String?               @db.Text
  preventiveAction  String?               @db.Text
  resolvedAt        DateTime?
  projectId         String
  project           Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reportedById      String
