// API Connection Types
enum ApiConnectionType {
  EXTERNAL
  INTERNAL
}

enum ApiConnectionStatus {
  ACTIVE
  INACTIVE
  ERROR
  EXPIRED
  DISABLED
}

enum ApiEnvironment {
  DEVELOPMENT
  STAGING
  PRODUCTION
}

// Integration categories for plug-and-play API management
enum IntegrationCategory {
  EMAIL_DELIVERY
  AI_PROCESSING
  PAYMENT_PROCESSING
  CLOUD_STORAGE
  AUTHENTICATION
  NOTIFICATIONS
  ANALYTICS
  DOCUMENT_PROCESSING
  COMMUNICATION
  OTHER
}

// API Connection Management for Super Admin
model ApiConnection {
  id          String            @id @default(cuid())
  name        String // Display name (e.g., "SendGrid Email Service")
  serviceName String // Service identifier (e.g., "sendgrid", "openai")
  description String?           @db.Text
  type        ApiConnectionType @default(EXTERNAL)
  environment ApiEnvironment    @default(PRODUCTION)

  // Plug-and-play categorization
  category IntegrationCategory @default(OTHER)
  purpose  String? // Brief description of what this integration does

  // Configuration schema (JSON schema for required fields)
  configSchema Json? @default("{}")

  // Module dependencies - which modules rely on this integration
  dependentModules String[] @default([])

  // Encrypted credentials stored as JSON
  credentials Json // { apiKey: "encrypted...", secretKey: "encrypted...", etc. }

  // Connection details
  baseUrl String? // API base URL
  version String? // API version
  headers Json?   @default("{}") // Default headers

  // Status tracking
  status            ApiConnectionStatus @default(ACTIVE)
  lastValidatedAt   DateTime?
  lastErrorMessage  String?             @db.Text
  consecutiveErrors Int                 @default(0)

  // Health metrics
  lastSuccessAt DateTime?
  lastFailureAt DateTime?
  successCount  Int       @default(0)
  failureCount  Int       @default(0)

  // Rate limiting info
  rateLimitInfo Json? @default("{}")

  // Metadata
  isEnabled     Boolean   @default(true)
  isBuiltIn     Boolean   @default(false) // Platform-provided vs user-configured
  isRequired    Boolean   @default(false) // Required for core functionality
  autoReconnect Boolean   @default(true) // Auto-reconnect on failures
  expiresAt     DateTime? // For keys with expiry

  // Audit
  createdById      String?
  createdBy        User?    @relation("ApiConnectionCreator", fields: [createdById], references: [id])
  lastModifiedById String?
  lastModifiedBy   User?    @relation("ApiConnectionModifier", fields: [lastModifiedById], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  logs            ApiConnectionLog[]
  healthChecks    ApiHealthCheck[]
  usageRecords    ApiUsageRecord[]
  rateLimitConfig ApiRateLimitConfig?

  @@unique([serviceName, environment])
  @@index([status])
  @@index([type])
  @@index([environment])
  @@index([category])
  @@index([isBuiltIn])
}

// Audit log for all API connection changes
model ApiConnectionLog {
  id           String        @id @default(cuid())
  connectionId String
  connection   ApiConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  action         String // created, updated, tested, rotated, disabled, enabled, deleted
  details        Json? // Additional action details
  previousStatus String?
  newStatus      String?

  // Test results
  testSuccess      Boolean?
  testResponseTime Int? // milliseconds
  testErrorMessage String?  @db.Text

  // Actor (optional for system-level operations)
  performedById String?
  performedBy   User?   @relation("ApiConnectionAuditor", fields: [performedById], references: [id])
  ipAddress     String?
  userAgent     String?

  createdAt DateTime @default(now())

  @@index([connectionId])
  @@index([action])
  @@index([createdAt])
}

// API Health Check Results - for uptime monitoring
model ApiHealthCheck {
  id           String        @id @default(cuid())
  connectionId String
  connection   ApiConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  // Health check results
  isHealthy    Boolean
  responseTime Int // milliseconds
  statusCode   Int?
  errorMessage String? @db.Text

  // Metadata
  checkType String  @default("scheduled") // scheduled, manual, webhook
  endpoint  String? // The endpoint checked

  createdAt DateTime @default(now())

  @@index([connectionId])
  @@index([createdAt])
  @@index([isHealthy])
}

// API Usage Analytics - tracks request counts and errors
model ApiUsageRecord {
  id           String        @id @default(cuid())
  connectionId String
  connection   ApiConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  // Time bucket (hourly aggregation)
  hourBucket DateTime // Truncated to hour

  // Counters
  requestCount   Int @default(0)
  successCount   Int @default(0)
  errorCount     Int @default(0)
  totalLatencyMs Int @default(0) // Sum of response times

  // Error breakdown (JSON: { "400": 5, "500": 2, etc. })
  errorsByCode Json? @default("{}")

  // Request types (JSON: { "GET": 100, "POST": 50, etc. })
  requestsByMethod Json? @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([connectionId, hourBucket])
  @@index([connectionId])
  @@index([hourBucket])
}

// Rate Limit Configuration - per-service rate limiting
model ApiRateLimitConfig {
  id           String        @id @default(cuid())
  connectionId String        @unique
  connection   ApiConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  // Rate limit settings
  requestsPerMinute Int @default(60)
  requestsPerHour   Int @default(1000)
  requestsPerDay    Int @default(10000)

  // Burst settings
  burstLimit Int @default(10) // Max requests in 1 second

  // Throttling behavior
  throttleOnLimit  Boolean @default(true)
  alertOnThreshold Boolean @default(true)
  alertThreshold   Int     @default(80) // Percentage of limit

  // Current usage tracking (updated periodically)
  currentMinuteUsage Int      @default(0)
  currentHourUsage   Int      @default(0)
  currentDayUsage    Int      @default(0)
  usageResetAt       DateTime @default(now())

  isEnabled Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([connectionId])
}

