model SiteDiaryEntry {
  id          String         @id @default(cuid())
  siteDiaryId String
  siteDiary   SiteDiary      @relation(fields: [siteDiaryId], references: [id], onDelete: Cascade)
  time        DateTime?
  type        DiaryEntryType @default(GENERAL)
  description String         @db.Text
