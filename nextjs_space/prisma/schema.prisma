// Worker Certification Type
enum CertificationType {
  CSCS_CARD
  CPCS_CARD
  IPAF_LICENSE
  PASMA_CERTIFICATE
  FIRST_AID
  FIRE_MARSHAL
  ASBESTOS_AWARENESS
  MANUAL_HANDLING
  WORKING_AT_HEIGHT
