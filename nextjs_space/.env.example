# ============================================================
# CortexBuild Pro — Next.js Environment Variables
# ============================================================
# Copy to .env.local for development:
#   cp .env.example .env.local
# ============================================================

# ── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://cortexbuild:your_password@localhost:5432/cortexbuild?schema=public"

# ── NextAuth ───────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-key"
NEXTAUTH_URL="http://localhost:3000"

# ── Google OAuth (optional) ────────────────────────────────
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# ── GitHub OAuth (optional) ────────────────────────────────
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""

# ── Ollama AI (local LLM — default provider) ───────────────
# Install Ollama: https://ollama.com/download
# Pull model: ollama pull qwen2.5:7b
OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL="qwen2.5:7b"

# ── Google AI / Gemini (cloud LLM — alternative provider) ──
# Get API key from: https://aistudio.google.com/apikey
# GEMINI_API_KEY="your-gemini-api-key"
# DEFAULT_GEMINI_MODEL="gemini-2.0-flash"

# ── AI Provider Selection ──────────────────────────────────
# Set to 'ollama' for local models, 'gemini' for Google AI (default: ollama)
# AI_PROVIDER="ollama"
# DEFAULT_AI_PROVIDER="ollama"

# ── AWS S3 (optional — file uploads) ──────────────────────
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_BUCKET_NAME=""
# AWS_FOLDER_PREFIX="cortexbuild/"
# AWS_REGION="eu-west-2"

# ── Email: SendGrid (optional) ─────────────────────────────
# SENDGRID_API_KEY=""
# SENDGRID_FROM_EMAIL="noreply@yourdomain.com"
# SENDGRID_FROM_NAME="CortexBuild Pro"

# ── WebSocket / real-time ──────────────────────────────────
NEXT_PUBLIC_WEBSOCKET_URL="http://localhost:3000"
WEBSOCKET_PORT="3000"

# ── AbacusAI / Push Notifications (optional) ──────────────
# Used for in-app push notifications via AbacusAI
# ABACUSAI_API_KEY=""    # AbacusAI deployment token
# WEB_APP_ID=""          # AbacusAI Web App ID

# ── Firebase Cloud Messaging — Notification Topics (optional)
# These topic IDs are used to send targeted push notifications.
# NOTIF_ID_TASKASSIGNMENT=""
# NOTIF_ID_COMPANYINVITATION=""
# NOTIF_ID_TEAM_MEMBERINVITATION=""
# NOTIF_ID_PROJECT_STATUSUPDATE=""
# NOTIF_ID_DAILY_REPORTSUBMITTED=""
# NOTIF_ID_MILESTONE_DEADLINEREMINDER=""
# NOTIF_ID_SAFETYALERT=""
# NOTIF_ID_TOOLBOX_TALKCOMPLETED=""
# NOTIF_ID_TOOL_CHECKCOMPLETED=""
# NOTIF_ID_MEWP_CHECKCOMPLETED=""

# ── Redis / BullMQ (optional — background jobs) ────────────
# REDIS_URL="redis://localhost:6379"

# ── Rate Limiting ──────────────────────────────────────────
# RATE_LIMIT_WINDOW_MS="60000"
# RATE_LIMIT_MAX_REQUESTS="100"
