# Database
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# NextAuth
NEXTAUTH_SECRET="your-nextauth-secret-key"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (Optional - for Google Sign-In)
# GOOGLE_CLIENT_ID="your-google-client-id"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"

# AWS S3 (Optional - for file uploads)
AWS_BUCKET_NAME="your-bucket-name"
AWS_FOLDER_PREFIX="cortexbuild/"
AWS_REGION="us-east-1"

# LLM API (Optional - for AI features)
# Abacus AI - Primary AI provider
ABACUSAI_API_KEY="your-abacus-api-key"

# Google Gemini API (Optional - Alternative AI provider)
# Get your API key from: https://makersuite.google.com/app/apikey
# GEMINI_API_KEY="your-gemini-api-key"

# AI Provider Selection (abacus or gemini)
# AI_PROVIDER="abacus"

# SendGrid Email Service (Optional - for transactional emails)
# Get your API key from: https://app.sendgrid.com/settings/api_keys
# SENDGRID_API_KEY="SG.your_api_key_here"
# SENDGRID_FROM_EMAIL="noreply@your-domain.com"
# SENDGRID_FROM_NAME="CortexBuild Pro"
