{
    "name": "cortexbuildpro.com",
    "private": true,
    "version": "2.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "dev:next": "next dev -p 3002",
        "dev:advanced": "concurrently \"npm run server\" \"npm run dev:next\"",
        "server": "tsx server/index.ts",
        "dev:all": "concurrently \"npm run dev\" \"npm run server\"",
        "build": "npm run build:frontend",
        "build:frontend": "VITE_API_URL=https://api.cortexbuildpro.com/api VITE_WS_URL=wss://api.cortexbuildpro.com/live vite build",
        "build:backend": "cd server && npm install && npm run build",
        "build:prod": "npm run build:frontend && npm run build:backend",
        "preview": "vite preview",
        "start": "NODE_ENV=production node server/index.js",
        "deploy:vps": "bash ./scripts/build-and-deploy-vps.sh",
        "deploy:vps:run": "bash ./scripts/build-and-deploy-vps.sh",
        "vercel:dev": "vercel dev",
        "vercel:deploy": "vercel",
        "vercel:prod": "vercel --prod",
        "lint": "eslint 'src/**/*.{ts,tsx}'",
        "db:backup": "chmod +x scripts/backup-database.sh && ./scripts/backup-database.sh",
        "db:restore": "chmod +x scripts/restore-database.sh && ./scripts/restore-database.sh",
        "db:health": "curl -s https://api.cortexbuildpro.com/api/health",
        "db:optimize": "tsx server/apply-indexes.ts",
        "test": "NODE_OPTIONS=--experimental-vm-modules jest --forceExit",
        "test:open-handles": "NODE_OPTIONS=--experimental-vm-modules jest --runInBand --detectOpenHandles",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:headed": "playwright test --headed",
        "test:e2e:debug": "playwright test --debug",
        "analyze:bundle": "./scripts/analyze-bundle.sh",
        "analyze:db": "tsx scripts/analyze-db-performance.ts",
        "analyze:all": "npm run analyze:bundle && npm run analyze:db"
    },
