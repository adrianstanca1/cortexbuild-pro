# ============================================================
# CortexBuild Pro - Deployment Environment Configuration
# ============================================================
# This file is used by docker-compose.yml for production deployment.
# Copy to .env and fill in your values before deploying.
#
# Quick Setup:
#   cp .env.example .env
#   nano .env
#   chmod 600 .env
#
# For the complete environment variable reference with detailed
# documentation, see: ../.env.template
# ============================================================

# -------------------------
# Docker / PostgreSQL (used by docker-compose to create DB container)
# -------------------------
# Generate password with: openssl rand -base64 24
POSTGRES_USER=cortexbuild
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=cortexbuild

# Optional: Pin a specific Docker image tag for deterministic deploys
# Format: cortexbuildpro-<git-sha>
# DOCKER_IMAGE_TAG=cortexbuildpro

# -------------------------
# NextAuth.js Configuration (REQUIRED)
# -------------------------
# Secret for JWT encryption (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Your application URL (no trailing slash, use HTTPS in production)
NEXTAUTH_URL="https://www.cortexbuildpro.com"

# Encryption key for sensitive data (generate with: openssl rand -hex 32)
ENCRYPTION_KEY="generate-with-openssl-rand-hex-32"

# -------------------------
# AWS S3 Configuration (REQUIRED for file uploads)
# -------------------------
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_BUCKET_NAME=""
AWS_REGION="eu-west-2"
AWS_FOLDER_PREFIX="cortexbuild/"

# -------------------------
# AI Features
# -------------------------
# AbacusAI API key (get from https://abacus.ai/)
ABACUSAI_API_KEY=""

# Google Gemini API key (alternative AI provider, optional)
# GEMINI_API_KEY=""

# AI Provider Selection: abacus or gemini (default: abacus)
# AI_PROVIDER="abacus"

# -------------------------
# Google OAuth (Optional)
# -------------------------
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# -------------------------
# Email: SendGrid (Optional)
# -------------------------
# SENDGRID_API_KEY=""
# SENDGRID_FROM_EMAIL="noreply@your-domain.com"
# SENDGRID_FROM_NAME="CortexBuild Pro"

# -------------------------
# Email: Custom SMTP (Optional, alternative to SendGrid)
# -------------------------
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASSWORD=""
# EMAIL_FROM="noreply@your-domain.com"

# -------------------------
# Real-time WebSocket (Optional)
# -------------------------
NEXT_PUBLIC_WEBSOCKET_URL="https://www.cortexbuildpro.com"
WEBSOCKET_PORT="3000"

# -------------------------
# Domain & SSL (Production)
# -------------------------
# DOMAIN="your-domain.com"
# SSL_EMAIL="admin@your-domain.com"
