# ============================================================
# CortexBuild Pro - Production Environment Configuration
# ============================================================
# Copy this to .env.production and fill in your values
# 
# Quick Setup:
#   cp .env.production.template .env.production
#   nano .env.production
#   chmod 600 .env.production
# ============================================================

# ============================================================
# DATABASE CONFIGURATION (Required)
# ============================================================
# Generate password with: openssl rand -base64 24
POSTGRES_USER=cortexbuild
POSTGRES_PASSWORD=CHANGE_ME_use_openssl_rand_base64_24
POSTGRES_DB=cortexbuild

# ============================================================
# NEXTAUTH.JS CONFIGURATION (Required)
# ============================================================
# Generate secret with: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_use_openssl_rand_base64_32"

# Your production URL (use HTTPS, no trailing slash)
NEXTAUTH_URL="https://www.cortexbuildpro.com"

# ============================================================
# ENCRYPTION (Required)
# ============================================================
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="CHANGE_ME_use_openssl_rand_hex_32"

# ============================================================
# AWS S3 CONFIGURATION (Required for file uploads)
# ============================================================
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_BUCKET_NAME=""
AWS_REGION="eu-west-2"
AWS_FOLDER_PREFIX="cortexbuild/"

# ============================================================
# AI FEATURES - Ollama (Default/Recommended)
# ============================================================
# AI provider: ollama (default), abacus, or gemini
AI_PROVIDER="ollama"

# Ollama runs on HOST, containers access via host.docker.internal
# Install: https://ollama.com/download | Pull: ollama pull qwen2.5:7b
OLLAMA_URL="http://host.docker.internal:11434"
OLLAMA_MODEL="qwen2.5:7b"

# Cloud AI fallbacks (optional)
# ABACUSAI_API_KEY=""
# GEMINI_API_KEY=""

# ============================================================
# OAUTH CONFIGURATION (Optional)
# ============================================================
# Google OAuth
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# GitHub OAuth
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""

# ============================================================
# EMAIL CONFIGURATION (Optional)
# ============================================================
# SendGrid
# SENDGRID_API_KEY=""
# SENDGRID_FROM_EMAIL="noreply@your-domain.com"
# SENDGRID_FROM_NAME="CortexBuild Pro"

# Custom SMTP (alternative to SendGrid)
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASSWORD=""
# EMAIL_FROM="noreply@your-domain.com"

# ============================================================
# WEBSOCKET CONFIGURATION (Optional)
# ============================================================
NEXT_PUBLIC_WEBSOCKET_URL="https://www.cortexbuildpro.com"
WEBSOCKET_PORT="3000"

# ============================================================
# DOMAIN & SSL (Required for HTTPS)
# ============================================================
DOMAIN="your-domain.com"
SSL_EMAIL="admin@your-domain.com"

# ============================================================
# MONITORING (Optional - for Grafana/Prometheus)
# ============================================================
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=your-secure-password
# GRAFANA_ROOT_URL=https://grafana.your-domain.com

# ============================================================
# SLACK/SENDGRID FOR ALERTS (Optional)
# ============================================================
# SLACK_WEBHOOK_URL=""
# SENDGRID_API_KEY=""

# ============================================================
# RESOURCE LIMITS (Optional)
# ============================================================
# APP_MEMORY_LIMIT=2G
# APP_CPU_LIMIT=2.0

# ============================================================
# SECURITY NOTES
# ============================================================
# 1. Never commit this file with real values
# 2. Use strong passwords (min 16 chars)
# 3. Rotate secrets regularly
# 4. Set file permissions: chmod 600 .env.production
