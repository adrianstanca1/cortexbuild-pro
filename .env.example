# ============================================================
# CortexBuild Pro - Environment Configuration
# ============================================================
# Copy to .env and fill in your values:
#   cp .env.example .env
#   chmod 600 .env
#
# For the FULL reference with detailed docs, see: .env.template
# For Docker deployment, see: deployment/.env.example
# ============================================================

# ========================================
# DATABASE (REQUIRED)
# ========================================
# PostgreSQL connection string (used by Prisma / NextAuth)
# Development: postgresql://cortexbuild:localdev@localhost:5433/cortexbuild?schema=public
# Production:  postgresql://cortexbuild:STRONG_PASS@db:5432/cortexbuild?schema=public
DATABASE_URL="postgresql://cortexbuild:changeme@localhost:5433/cortexbuild?schema=public"

# Docker PostgreSQL container credentials (must match DATABASE_URL above)
POSTGRES_USER=cortexbuild
POSTGRES_PASSWORD=changeme
POSTGRES_DB=cortexbuild

# ========================================
# AUTHENTICATION (REQUIRED)
# ========================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_generate_with_openssl_rand_base64_32"

# Your app URL (no trailing slash, HTTPS in production)
NEXTAUTH_URL="http://localhost:3000"

# Data encryption key (generate with: openssl rand -hex 32)
ENCRYPTION_KEY="CHANGE_ME_generate_with_openssl_rand_hex_32"

# ========================================
# AWS S3 STORAGE (REQUIRED for file uploads)
# ========================================
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_BUCKET_NAME=""
AWS_REGION="eu-west-2"
AWS_FOLDER_PREFIX="cortexbuild/"

# ========================================
# AI FEATURES
# ========================================
# AbacusAI (primary) - get from https://abacus.ai/
ABACUSAI_API_KEY=""

# Google Gemini (optional alternative) - get from https://aistudio.google.com
# GEMINI_API_KEY=""
# AI_PROVIDER="abacus"

# ========================================
# GOOGLE OAUTH (OPTIONAL)
# ========================================
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# ========================================
# EMAIL SERVICE (OPTIONAL - choose one)
# ========================================

# SendGrid (https://sendgrid.com/)
# SENDGRID_API_KEY=""
# SENDGRID_FROM_EMAIL="noreply@cortexbuildpro.com"
# SENDGRID_FROM_NAME="CortexBuild Pro"

# Custom SMTP (alternative to SendGrid)
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASSWORD=""
# EMAIL_FROM="noreply@cortexbuildpro.com"

# ========================================
# STRIPE PAYMENTS (OPTIONAL)
# ========================================
# STRIPE_SECRET_KEY=""
# STRIPE_PUBLISHABLE_KEY=""
# STRIPE_WEBHOOK_SECRET=""

# ========================================
# WEBSOCKET (OPTIONAL)
# ========================================
NEXT_PUBLIC_WEBSOCKET_URL="http://localhost:3000"
WEBSOCKET_PORT="3000"

# ========================================
# FRONTEND (Vite build only)
# ========================================
VITE_API_URL="http://localhost:3001/api"
VITE_WS_URL="ws://localhost:3001/live"
# VITE_GEMINI_API_KEY=""
# VITE_SENTRY_DSN=""

# ========================================
# MONITORING (OPTIONAL)
# ========================================
# SENTRY_DSN=""

# ========================================
# DOMAIN & SSL (Production only)
# ========================================
# DOMAIN="cortexbuildpro.com"
# SSL_EMAIL="admin@cortexbuildpro.com"

# ========================================
# LEGACY: Express Backend (server/ only)
# ========================================
# These are used by the Express server if running standalone.
# Not needed for the Next.js deployment (Docker).
# JWT_SECRET="your_jwt_secret_here"
# DATABASE_TYPE=mysql
# DB_HOST=127.0.0.1
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password
# DB_NAME=your_db_name
# DB_PORT=3306
# VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""
