# Environment Variables Template
# Copy this file to .env and fill in your actual values

# ========================================
# DATABASE CONFIGURATION
# ========================================
# Database type: sqlite (local dev), postgres, or mysql (production/Hostinger)
# For local development with SQLite, set DATABASE_TYPE=sqlite or USE_LOCAL_DB=true
# For production MySQL (Hostinger), use DATABASE_TYPE=mysql with credentials below
DATABASE_TYPE=mysql
# DB_HOST: Use 127.0.0.1 for local MySQL on same server, or remote hostname
DB_HOST=127.0.0.1
DB_USER=u875310796_admin
DB_PASSWORD=your_hostinger_password
DB_NAME=u875310796_cortexbuildpro
DB_PORT=3306

# ========================================
# APPLICATION SECRETS
# ========================================
JWT_SECRET=your_jwt_secret_here
FILE_SIGNING_SECRET=your_file_signing_secret
NODE_ENV=production
PORT=3001

# ========================================
# EXTERNAL SERVICES
# ========================================

# SendGrid (Email)
SENDGRID_API_KEY=SG.your_sendgrid_key
EMAIL_FROM=noreply@cortexbuildpro.com

# SendGrid Templates (Optional - for dynamic templates)
SENDGRID_TEMPLATE_INVITATION=d-xxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_ACTIVATION=d-xxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_PASSWORD_RESET=d-xxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_EMAIL_VERIFICATION=d-xxxxxxxxxxxxxxxxxxxxx

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://api.cortexbuildpro.com/api/auth/google/callback

# Gemini AI
GEMINI_API_KEY=your_gemini_key_here

# Web Push Notifications
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# ========================================
# SAAS FEATURES
# ========================================

# Stripe Payment Processing
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Trial System
TRIAL_DURATION_DAYS=30
TRIAL_WARNING_DAYS=7,3,1

# ========================================
# MONITORING & ERROR TRACKING
# ========================================

# Sentry
SENTRY_DSN=your-sentry-dsn-here

# ========================================
# FRONTEND CONFIGURATION
# ========================================
VITE_API_URL=https://api.cortexbuildpro.com/api
VITE_WS_URL=wss://api.cortexbuildpro.com/live
VITE_GEMINI_API_KEY=your_gemini_key_here
VITE_SENTRY_DSN=your-frontend-sentry-dsn
FRONTEND_URL=https://cortexbuildpro.com
APP_URL=https://cortexbuildpro.com

# ========================================
# DEPLOYMENT CONFIGURATION
# ========================================

# Hostinger/VPS SSH Details
SSH_HOST=your-vps-ip
SFTP_USER=your-ftp-username
SFTP_PASSWORD=your-ftp-password

# ========================================
# STORAGE CONFIGURATION
# ========================================
STORAGE_ROOT=./storage
FILE_UPLOAD_MAX_SIZE=50MB
