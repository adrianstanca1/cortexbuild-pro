# FINAL PROXY VERSION
Options -Indexes -MultiViews
RewriteEngine On

# If it's a real file in the dist folder, allow it (for static mapping)
RewriteCond %{REQUEST_URI} ^/api/dist/.*$
RewriteRule ^(.*)$ - [L]

# Everything else goes through the PHP bridge
RewriteCond %{REQUEST_URI} !index\.php
RewriteRule ^(.*)$ index.php [L,QSA]
