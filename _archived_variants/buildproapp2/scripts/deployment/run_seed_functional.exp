#!/usr/bin/expect -f
set timeout -1

# Upload
spawn sftp -P 65002 -o StrictHostKeyChecking=no u875310796@82.29.191.97
expect "password:"
send "Cumparavinde1.\r"
expect "sftp>"
send "put server/dist/scripts/seed-functional-data.js domains/cortexbuildpro.com/server_app/dist/scripts/\r"
