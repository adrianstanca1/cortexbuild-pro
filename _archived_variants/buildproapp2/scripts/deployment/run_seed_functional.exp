# Execute
spawn ssh -p 65002 -o StrictHostKeyChecking=no u875310796@82.29.191.97 "cd domains/cortexbuildpro.com/server_app && /opt/alt/alt-nodejs20/root/usr/bin/node dist/scripts/seed-functional-data.js"
expect "password:"
send "Cumparavinde1.\r"
expect eof
