# ASAgents Platform - Development Environment Configuration

# Application Environment
NODE_ENV=development
ENVIRONMENT=development

# Frontend Configuration (Port 4000)
VITE_API_URL=http://localhost:4000/api
VITE_WS_URL=ws://localhost:5001/ws
VITE_APP_NAME=ASAgents Platform (Dev)
VITE_APP_VERSION=2.0.0-dev

# Backend Configuration (Express + SQLite backend on port 5001)
PORT=5001
HOST=localhost

# Database Configuration (SQLite)
DATABASE_PATH=./backend/data/database.sqlite
DATABASE_BACKUP_PATH=./backups

# JWT Configuration
JWT_SECRET=dev-jwt-secret-not-for-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# CORS Configuration (Allow localhost development)
CORS_ORIGIN=http://localhost:4000,http://localhost:3000,http://localhost:5173

# Security Configuration (Relaxed for development)
BCRYPT_ROUNDS=8
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx,txt

# Logging Configuration
LOG_LEVEL=debug
LOG_FILE=./logs/application.log

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30000
WS_MAX_CONNECTIONS=100

# Domain Configuration
DOMAIN=localhost
FRONTEND_URL=http://localhost:4000
BACKEND_URL=http://localhost:5001

# Development API Keys (use test keys only)
VITE_GOOGLE_CLIENT_ID=your-google-client-id-dev
VITE_GITHUB_CLIENT_ID=your-github-client-id-dev
VITE_GEMINI_API_KEY=your-gemini-api-key-dev

# Development Features
VITE_ENABLE_DEBUG=true
VITE_ENABLE_MOCK_DATA=false
VITE_ENABLE_PERFORMANCE_MONITORING=true
