# Environment Configuration for Docker Deployment
# Copy this file to .env and update with your values

# MySQL Database Configuration
MYSQL_ROOT_PASSWORD=your-strong-root-password-here
MYSQL_USER=asagents
MYSQL_PASSWORD=your-strong-password-here
MYSQL_DATABASE=asagents_db

# JWT Secret (use a strong random string)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long

# Node.js Backend Configuration
NODE_ENV=production
NODE_PORT=5001

# Java Backend Configuration
JAVA_PORT=4001
JAVA_OPTS=-Xms512m -Xmx1024m

# Frontend Configuration
VITE_API_BASE_URL=/api
VITE_NODE_BACKEND_URL=http://localhost:5001
VITE_JAVA_BACKEND_URL=http://localhost:4001

# Optional: Google Gemini API for AI features
GEMINI_API_KEY=your-gemini-api-key-here
