// TypeScript config that excludes problematic files during development
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "skipLibCheck": true,
    "noEmit": true
  },
  "exclude": [
    "node_modules",
    "dist",
    "components/views/AllTasksView.tsx",
    "components/views/EquipmentView.tsx", 
    "components/views/SafetyView.tsx",
    "components/views/TeamView.tsx",
    "components/WhiteboardView.tsx",
    "services/multimodal*.ts",
    "components/multimodal/**/*",
    "services/managers/APIManager.ts",
    "services/managers/SecurityManager.ts",
    "tests/e2e/user-workflows.test.ts"
  ]
}