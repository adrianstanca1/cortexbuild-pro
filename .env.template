# ============================================
# CortexBuild Pro - Complete Environment Configuration Template
# ============================================
# This file contains ALL possible environment variables for CortexBuild Pro
# Copy this to .env and fill in your actual values
# 
# Quick Setup:
#   cp .env.template .env
#   nano .env
#   chmod 600 .env
#
# Security: NEVER commit this file with real values to Git!
# See: ENVIRONMENT_SETUP_GUIDE.md for detailed instructions
# ============================================

# ============================================
# DATABASE CONFIGURATION (REQUIRED)
# ============================================

# PostgreSQL connection string
# Format: postgresql://username:password@hostname:port/database?schema=public
# 
# Development example:
#   DATABASE_URL="postgresql://cortexbuild:devpass@localhost:5432/cortexbuild?schema=public"
# 
# Production example (Docker):
#   DATABASE_URL="postgresql://cortexbuild:SECURE_PASSWORD@postgres:5432/cortexbuild?schema=public"
# 
# External database example:
#   DATABASE_URL="postgresql://user:pass@db.example.com:5432/cortexbuild?schema=public"
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# Docker-specific database configuration (deployment/.env only)
# Used by docker-compose to create PostgreSQL container
# Generate strong password with: openssl rand -base64 32
POSTGRES_USER=cortexbuild
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=cortexbuild

# ============================================
# NEXTAUTH CONFIGURATION (REQUIRED)
# ============================================

# Secret key for JWT encryption and session management
# MUST be at least 32 characters long
# Generate with: openssl rand -base64 32
# 
# Example: 3eZQkW8rX9mP5nT7vY2bC4dF6gH8jK0lM1nQ3sV5wX7z
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Your application's public URL
# Development: http://localhost:3000
# Production: https://www.cortexbuildpro.com
# 
# Requirements:
#   - No trailing slash
#   - Use HTTPS in production
#   - Must match your actual domain
NEXTAUTH_URL="http://localhost:3000"

# ============================================
# AWS S3 CONFIGURATION (REQUIRED)
# ============================================

# AWS region where your S3 bucket is located
# Common options: us-east-1, us-west-2, eu-west-1, ap-southeast-1
AWS_REGION="us-west-2"

# Name of your S3 bucket for file storage
# Must be globally unique across all AWS accounts
# Example: cortexbuild-prod-files
AWS_BUCKET_NAME="your-bucket-name"

# Folder prefix for organizing files in S3 (optional but recommended)
# Trailing slash is recommended
# Example: production/ or cortexbuild/prod/
AWS_FOLDER_PREFIX="your-folder-prefix/"

# AWS Credentials - Method 1: Environment Variables (Recommended for Production)
# Create IAM user with S3 permissions and generate access keys
# Get from: AWS Console → IAM → Users → Security credentials
AWS_ACCESS_KEY_ID="your-access-key-id"
AWS_SECRET_ACCESS_KEY="your-secret-access-key"

# AWS Credentials - Method 2: AWS Profile (Development)
# Use AWS CLI configured profile instead of direct credentials
# Setup with: aws configure --profile hosted_storage
# Uncomment if using profile instead of direct credentials:
# AWS_PROFILE="hosted_storage"

# ============================================
# ABACUSAI API CONFIGURATION (REQUIRED)
# ============================================

# AbacusAI API key for AI features and notifications
# Get from: https://abacus.ai/ → Settings → API Keys
# Example: abacus_xxxxxxxxxxxxxxxxxxxxx
ABACUSAI_API_KEY="your-abacus-api-key"

# Optional: AbacusAI Web App ID (for hosted features)
# Get from: AbacusAI dashboard → Applications
# WEB_APP_ID="your-web-app-id"

# Optional: Notification IDs for AbacusAI push notifications
# Get from: AbacusAI dashboard → Notifications → Templates
# Only needed if using AbacusAI notification service
# NOTIF_ID_MILESTONE_DEADLINE_REMINDER="your-notif-id"
# NOTIF_ID_TOOLBOX_TALK_COMPLETED="your-notif-id"
# NOTIF_ID_MEWP_CHECK_COMPLETED="your-notif-id"
# NOTIF_ID_TOOL_CHECK_COMPLETED="your-notif-id"

# ============================================
# GOOGLE OAUTH (OPTIONAL)
# ============================================

# Enable "Sign in with Google" functionality
# Setup guide: https://console.cloud.google.com/
# 
# Steps:
#   1. Create project in Google Cloud Console
#   2. Enable Google+ API
#   3. Create OAuth 2.0 credentials
#   4. Add authorized redirect URIs:
#      - http://localhost:3000/api/auth/callback/google (dev)
#      - https://your-domain.com/api/auth/callback/google (prod)
#   5. Copy Client ID and Client Secret below

# GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ============================================
# SENDGRID EMAIL SERVICE (OPTIONAL)
# ============================================

# SendGrid for transactional emails (invitations, notifications, password resets)
# Free tier: 100 emails/day
# Get API key: https://app.sendgrid.com/settings/api_keys
# 
# Setup:
#   1. Sign up at https://sendgrid.com/
#   2. Verify sender identity (Settings → Sender Authentication)
#   3. Create API key with Mail Send permission
#   4. Configure sender email and name below
# 
# Fallback: If not configured, app uses AbacusAI for email delivery

# SendGrid API key (starts with SG.)
# SENDGRID_API_KEY="SG.your_api_key_here"

# Verified sender email address
# Must be verified in SendGrid dashboard
# SENDGRID_FROM_EMAIL="noreply@your-domain.com"

# Display name for sent emails
# SENDGRID_FROM_NAME="CortexBuild Pro"

# ============================================
# CUSTOM SMTP EMAIL (OPTIONAL - ALTERNATIVE TO SENDGRID)
# ============================================

# Use your own SMTP server for email delivery
# Alternative to SendGrid
# 
# Common providers:
#   Gmail: smtp.gmail.com:587 (use App Password, not regular password)
#   Outlook: smtp.office365.com:587
#   Custom: your-mail-server.com:587

# SMTP server hostname
# SMTP_HOST="smtp.gmail.com"

# SMTP server port (usually 587 for TLS or 465 for SSL)
# SMTP_PORT="587"

# SMTP authentication username (usually your email address)
# SMTP_USER="your-email@gmail.com"

# SMTP authentication password
# For Gmail, generate App Password: https://myaccount.google.com/apppasswords
# SMTP_PASSWORD="your-app-password"

# Email address to use as sender
# EMAIL_FROM="noreply@your-domain.com"

# ============================================
# REAL-TIME WEBSOCKET CONFIGURATION (OPTIONAL)
# ============================================

# WebSocket server URL for real-time updates, chat, and notifications
# Must be accessible from client browsers
# 
# Development: http://localhost:3000
# Production: https://www.cortexbuildpro.com (use HTTPS/WSS)
# 
# Note: NEXT_PUBLIC_ prefix makes this available in browser
NEXT_PUBLIC_WEBSOCKET_URL="http://localhost:3000"

# WebSocket server port
# Should match your application port
WEBSOCKET_PORT="3000"

# ============================================
# DOMAIN CONFIGURATION (PRODUCTION ONLY)
# ============================================

# Your production domain (without www or https://)
# Used for: SSL certificate generation, email configuration
# Example: cortexbuildpro.com
# DOMAIN="your-domain.com"

# Email address for SSL certificate notifications
# Used by Let's Encrypt for renewal reminders
# SSL_EMAIL="admin@your-domain.com"

# ============================================
# SECURITY CONFIGURATION (OPTIONAL)
# ============================================

# Application environment
# Options: development, production, test
# Default: development
# NODE_ENV="development"

# Enable/disable debug logging
# Options: true, false
# Default: false in production
# DEBUG="false"

# Session cookie name (optional)
# Default: next-auth.session-token
# NEXTAUTH_COOKIE_NAME="next-auth.session-token"

# ============================================
# FEATURE FLAGS (OPTIONAL)
# ============================================

# Enable/disable specific features
# Useful for gradual rollout or A/B testing

# Enable AI-powered features
# ENABLE_AI_FEATURES="true"

# Enable real-time collaboration
# ENABLE_REALTIME="true"

# Enable email notifications
# ENABLE_EMAIL_NOTIFICATIONS="true"

# Enable Google OAuth login
# ENABLE_GOOGLE_OAUTH="false"

# ============================================
# MONITORING & LOGGING (OPTIONAL)
# ============================================

# Sentry DSN for error tracking (optional)
# Get from: https://sentry.io/
# SENTRY_DSN="https://xxxxx@sentry.io/xxxxx"

# Log level (optional)
# Options: error, warn, info, debug
# LOG_LEVEL="info"

# ============================================
# RATE LIMITING (OPTIONAL)
# ============================================

# Rate limit for API endpoints (requests per minute)
# Default: 60
# RATE_LIMIT_RPM="60"

# Rate limit window in minutes
# Default: 1
# RATE_LIMIT_WINDOW="1"

# ============================================
# FILE UPLOAD LIMITS (OPTIONAL)
# ============================================

# Maximum file upload size in MB
# Default: 50
# MAX_FILE_SIZE_MB="50"

# Allowed file types (comma-separated)
# Default: pdf,doc,docx,xls,xlsx,jpg,jpeg,png,gif
# ALLOWED_FILE_TYPES="pdf,doc,docx,xls,xlsx,jpg,jpeg,png,gif"

# ============================================
# DATABASE OPTIMIZATION (OPTIONAL)
# ============================================

# Connection pool size
# Default: 10
# DATABASE_POOL_SIZE="10"

# Connection timeout in seconds
# Default: 20
# DATABASE_TIMEOUT="20"

# Enable query logging (development only)
# DATABASE_LOGGING="false"

# ============================================
# CACHE CONFIGURATION (OPTIONAL)
# ============================================

# Redis connection URL (if using Redis for caching)
# Format: redis://username:password@hostname:port
# REDIS_URL="redis://localhost:6379"

# Cache TTL in seconds
# Default: 3600 (1 hour)
# CACHE_TTL="3600"

# ============================================
# BACKUP CONFIGURATION (OPTIONAL)
# ============================================

# S3 bucket for database backups (can be different from main bucket)
# BACKUP_BUCKET_NAME="cortexbuild-backups"

# Backup retention days
# BACKUP_RETENTION_DAYS="30"

# Automatic backup schedule (cron format)
# Default: Daily at 2 AM
# BACKUP_SCHEDULE="0 2 * * *"

# ============================================
# ANALYTICS (OPTIONAL)
# ============================================

# Google Analytics tracking ID
# Get from: https://analytics.google.com/
# GA_TRACKING_ID="G-XXXXXXXXXX"

# PostHog API key (for product analytics)
# Get from: https://posthog.com/
# POSTHOG_API_KEY="phc_xxxxxxxxxxxxx"

# ============================================
# THIRD-PARTY INTEGRATIONS (OPTIONAL)
# ============================================

# Slack webhook for notifications
# Get from: Slack → Apps → Incoming Webhooks
# SLACK_WEBHOOK_URL="https://hooks.slack.com/services/XXX/YYY/ZZZ"

# Twilio for SMS notifications
# Get from: https://www.twilio.com/console
# TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxx"
# TWILIO_AUTH_TOKEN="your-auth-token"
# TWILIO_PHONE_NUMBER="+1234567890"

# ============================================
# DEVELOPMENT TOOLS (DEVELOPMENT ONLY)
# ============================================

# Prisma Studio port
# Default: 5555
# PRISMA_STUDIO_PORT="5555"

# Enable React DevTools
# REACT_DEVTOOLS="true"

# Enable Next.js telemetry
# NEXT_TELEMETRY_DISABLED="false"

# ============================================
# NOTES AND REMINDERS
# ============================================

# Security Checklist:
# [ ] All sensitive values filled in
# [ ] NEXTAUTH_SECRET is 32+ characters
# [ ] Database password is strong (24+ characters)
# [ ] AWS credentials are from dedicated IAM user
# [ ] File permissions set: chmod 600 .env
# [ ] This file is in .gitignore
# [ ] GitHub secrets configured (see GITHUB_SECRETS_GUIDE.md)
# [ ] Different values for development and production

# Generation Commands:
# Secure random password: openssl rand -base64 32
# Secure random hex: openssl rand -hex 32
# UUID: uuidgen

# Verification:
# Test database: psql "$DATABASE_URL"
# Run diagnostics: cd nextjs_space && npx tsx scripts/system-diagnostics.ts
# Check config: ./verify-config.sh

# Documentation:
# See ENVIRONMENT_SETUP_GUIDE.md for detailed setup instructions
# See GITHUB_SECRETS_GUIDE.md for CI/CD configuration
# See SECURITY_CHECKLIST.md for security best practices
# See API_SETUP_GUIDE.md for API service configuration

# ============================================
# END OF CONFIGURATION
# ============================================
