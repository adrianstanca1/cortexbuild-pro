# Hostinger Production Environment Configuration
# Copy this file to .env.hostinger and fill in your actual production values
# DO NOT commit the actual .env.hostinger file with real credentials!

PORT=3001
NODE_ENV=REDACTED
DATABASE_TYPE=mysql
DB_HOST=127.0.0.1
DB_USER=REDACTED
DB_PASSWORD=REDACTED
DB_NAME=REDACTED
DB_PORT=3306
JWT_SECRET=REDACTED
FILE_SIGNING_SECRET=REDACTED
STORAGE_ROOT=./storage

# Web Push Notifications (generate at https://vapidkeys.com/)
VAPID_PUBLIC_KEY=REDACTED
VAPID_PRIVATE_KEY=REDACTED

# CORS allowed origins (Frontend URL)
CORS_ORIGIN=REDACTED

# API Keys
GEMINI_API_KEY=REDACTED
SENDGRID_API_KEY=REDACTED

# Application Configuration
USE_LOCAL_DB=false
APP_URL=REDACTED
EMAIL_FROM=REDACTED

# Sentry Monitoring (optional)
SENTRY_DSN=
