PORT=3001
NODE_ENV=production
# Database type: mysql for production, sqlite for local dev
DATABASE_TYPE=mysql

# Database Credentials
# DB_HOST: Use 127.0.0.1 for local MySQL, or remote hostname for external MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=u875310796_cortexbuildpro
DB_USER=u875310796_admin
DB_PASSWORD=your_hostinger_password

# Security
JWT_SECRET=your_jwt_secret_here


# Push Notifications
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# Services
EMAIL_FROM=noreply@cortexbuildpro.com
SENDGRID_API_KEY=SG.your_sendgrid_key
GEMINI_API_KEY=your_gemini_key_here

# CORS & Routing
CORS_ORIGIN=https://yourdomain.com
APP_URL=https://yourdomain.com
FILE_SIGNING_SECRET=your_file_signing_secret
STORAGE_ROOT=./storage
